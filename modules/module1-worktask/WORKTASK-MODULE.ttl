# ============================================================
# 第六部分：Placeholder 类（为本模块提供类型锚点）
# ============================================================
# 以下类在完整本体中由对应模块定义，此处声明为占位符
# 使得本模块可以独立通过语法验证

so:Event a owl:Class ;
    rdfs:label "事件"@zh-CN ;
    rdfs:label "Event"@en ;
    rdfs:comment "占位符：完整定义在 events 模块"@zh-CN .

# ============================================================
# 补充部分：SKU / 门店 / 员工 / 库存事件（支持临期推理）
# ============================================================
# 补全占位符，支撑 Demo A 推理链路：
#   给定 SKU + 当前库存 + 生产日期 → AI 推理折扣 → 生成 WorkTask

# --- SKU（商品）---
so:SKU a owl:Class ;
    rdfs:label "商品SKU"@zh-CN ;
    rdfs:label "SKU"@en ;
    rdfs:comment "商品SKU实体，包含保质期信息、品类归属、当前库存数量"@zh-CN .

so:skuCode a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "商品编码"@zh-CN ;
    rdfs:label "SKU Code"@en .

so:skuName a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "商品名称"@zh-CN ;
    rdfs:label "SKU Name"@en .

so:productionDate a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:date ;
    rdfs:label "生产日期"@zh-CN ;
    rdfs:label "Production Date"@en ;
    rdfs:comment "商品生产日期"@zh-CN .

so:expirationDate a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:date ;
    rdfs:label "到期日期"@zh-CN ;
    rdfs:label "Expiration Date"@en ;
    rdfs:comment "商品保质期到期日"@zh-CN .

so:currentQuantity a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:integer ;
    rdfs:label "当前库存数量"@zh-CN ;
    rdfs:label "Current Quantity"@en ;
    rdfs:comment "当前库存数量（件）"@zh-CN .

so:hasCategory a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:Category ;
    rdfs:label "所属品类"@zh-CN ;
    rdfs:label "Has Category"@en .

so:clearanceStatus a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:ClearanceStatus ;
    rdfs:label "出清状态"@zh-CN ;
    rdfs:label "Clearance Status"@en .

# 所属门店（SKU 归属哪个门店）
so:store a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:Store ;
    rdfs:label "所属门店"@zh-CN ;
    rdfs:label "Store"@en ;
    rdfs:comment "SKU 所属的门店，关联 so:Store 实体"@zh-CN ;
    owl:inverseOf so:hasSKU .

# 门店拥有的 SKU（逆属性）
so:hasSKU a owl:ObjectProperty ;
    rdfs:domain so:Store ;
    rdfs:range so:SKU ;
    rdfs:label "门店商品"@zh-CN ;
    rdfs:label "Has SKU"@en ;
    owl:inverseOf so:store .

# 商品ID（JSON product_id 映射到 TTL）
so:productId a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "商品ID"@zh-CN ;
    rdfs:label "Product ID"@en ;
    rdfs:comment "商品唯一标识，映射自 products.json 的 product_id 字段"@zh-CN .

# 库存（件）
so:stock a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:integer ;
    rdfs:label "库存数量"@zh-CN ;
    rdfs:label "Stock Quantity"@en ;
    rdfs:comment "当前库存件数"@zh-CN .

# 原价
so:originalPrice a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:decimal ;
    rdfs:label "原价"@zh-CN ;
    rdfs:label "Original Price"@en .

# 当前售价
so:currentPrice a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:decimal ;
    rdfs:label "当前售价"@zh-CN ;
    rdfs:label "Current Price"@en .

# 是否进口
so:isImported a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:boolean ;
    rdfs:label "是否进口"@zh-CN ;
    rdfs:label "Is Imported"@en .

# 是否有机
so:isOrganic a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:boolean ;
    rdfs:label "是否有机"@zh-CN ;
    rdfs:label "Is Organic"@en .

# 是否促销中
so:isPromoted a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:boolean ;
    rdfs:label "是否促销"@zh-CN ;
    rdfs:label "Is Promoted"@en .

# 到货天数
so:arrivalDays a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:integer ;
    rdfs:label "到货天数"@zh-CN ;
    rdfs:label "Days Since Arrival"@en ;
    rdfs:comment "商品到货至今的天数"@zh-CN .

# --- ClearanceStatus 枚举 ---
so:ClearanceStatus a owl:Class ;
    rdfs:label "出清状态"@zh-CN ;
    rdfs:comment "商品出清状态枚举"@zh-CN .

so:ClearanceStatusNormal a owl:NamedIndividual ;
    rdfs:label "正常"@zh-CN ;
    rdfs:subClassOf so:ClearanceStatus .

so:ClearanceStatusPending a owl:NamedIndividual ;
    rdfs:label "待出清"@zh-CN ;
    rdfs:subClassOf so:ClearanceStatus .

so:ClearanceStatusInProgress a owl:NamedIndividual ;
    rdfs:label "出清中"@zh-CN ;
    rdfs:subClassOf so:ClearanceStatus .

so:ClearanceStatusCompleted a owl:NamedIndividual ;
    rdfs:label "已出清"@zh-CN ;
    rdfs:subClassOf so:ClearanceStatus .

so:ClearanceStatusExempted a owl:NamedIndividual ;
    rdfs:label "豁免出清"@zh-CN ;
    rdfs:subClassOf so:ClearanceStatus .

# --- Store（门店）---
so:Store a owl:Class ;
    rdfs:label "门店"@zh-CN ;
    rdfs:label "Store"@en ;
    rdfs:comment "门店实体，包含门店编码、名称、地区信息"@zh-CN .

so:storeCode a owl:DatatypeProperty ;
    rdfs:domain so:Store ;
    rdfs:range xsd:string ;
    rdfs:label "门店编码"@zh-CN ;
    rdfs:label "Store Code"@en .

so:storeName a owl:DatatypeProperty ;
    rdfs:domain so:Store ;
    rdfs:range xsd:string ;
    rdfs:label "门店名称"@zh-CN ;
    rdfs:label "Store Name"@en .

so:region a owl:DatatypeProperty ;
    rdfs:domain so:Store ;
    rdfs:range xsd:string ;
    rdfs:label "所属地区"@zh-CN ;
    rdfs:label "Region"@en .

# --- Employee（员工）---
so:Employee a owl:Class ;
    rdfs:label "员工"@zh-CN ;
    rdfs:label "Employee"@en ;
    rdfs:comment "员工实体，包含工号、姓名、角色信息"@zh-CN .

so:employeeCode a owl:DatatypeProperty ;
    rdfs:domain so:Employee ;
    rdfs:range xsd:string ;
    rdfs:label "工号"@zh-CN ;
    rdfs:label "Employee Code"@en .

so:employeeName a owl:DatatypeProperty ;
    rdfs:domain so:Employee ;
    rdfs:range xsd:string ;
    rdfs:label "员工姓名"@zh-CN ;
    rdfs:label "Employee Name"@en .

so:employeeRole a owl:ObjectProperty ;
    rdfs:domain so:Employee ;
    rdfs:range so:EmployeeRole ;
    rdfs:label "员工角色"@zh-CN ;
    rdfs:label "Employee Role"@en .

so:worksAt a owl:ObjectProperty ;
    rdfs:domain so:Employee ;
    rdfs:range so:Store ;
