@prefix repair: <http://example.org/equipment-repair#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# 人员域（Personnel）—— customerA
# Employee + Technician（技师）都属于人员范畴
# ============================================================

repair:Employee a rdfs:Class ;
    rdfs:label "员工"@zh , "Employee"@en ;
    rdfs:comment "门店员工。user_id 反向引用 identity domain 的 User"@zh ;
    repair:properties "id:string,name:string,store_id:string,role:string,user_id:string,department_id:string,phone:string" ;
    repair:storage "employees.json" ;
    repair:status "active" ;
    repair:read_roles "*" .

# Link Types

repair:has_employee a rdfs:Property ;
    rdfs:label "拥有员工"@zh , "has employee"@en ;
    rdfs:comment "Store 的员工集合。via store_id 在 Employee（range 侧）上"@zh ;
    rdfs:domain repair:Store ; rdfs:range repair:Employee ; repair:via "store_id" .

repair:employed_as a rdfs:Property ;
    rdfs:label "受雇于用户"@zh , "employed as"@en ;
    rdfs:comment "Employee 通过 user_id（domain 侧）关联到 identity domain 的 User"@zh ;
    rdfs:domain repair:Employee ; rdfs:range repair:User ; repair:via "user_id" .
