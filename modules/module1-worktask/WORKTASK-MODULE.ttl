# ============================================================
# 门店本体论 module1：任务实体（WorkTask）
# ============================================================
# 版本: 0.1.0
# 日期: 2026-04-19
# 中心实体: WorkTask（作业任务）
# 第一个场景: 商品临期打折
#
# 建模范式: 事件触发 → 系统推理推荐 → 自动/人工确认 → 执行 → POS数据闭环 → 复核
#
# 设计原则（参考 Palantir 官方文档）:
#   - Object Type 代表现实世界实体，不是系统模块
#   - Property 和 Link Type 语义明确，名称自解释
#   - 枚举值使用 owl:NamedIndividual，通过 rdfs:subClassOf 归类
#   - 每个类独立声明，不使用 owl:equivalentClass 避免循环
#   - 逆属性（inverseOf）成对声明，确保推理一致性
# ============================================================

@prefix so:   <https://store-ontology.example.com/retail#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

@base <https://store-ontology.example.com/retail> .

<https://store-ontology.example.com/retail> a owl:Ontology ;
    owl:versionInfo "0.1.0" ;
    rdfs:label "门店自动化运营本体 v0.1.0"@zh-CN ;
    rdfs:label "Store Automation Ontology v0.1.0"@en ;
    rdfs:comment "以任务实体（WorkTask）为中心的门店自动化运营本体。核心场景：商品临期打折。闭环：事件触发→系统推理推荐→人工/自动确认→执行→POS数据闭环→复核。"@zh-CN .

# ============================================================
# 第一部分：WorkTask Object Type
# ============================================================

so:WorkTask a owl:Class ;
    rdfs:label "作业任务"@zh-CN ;
    rdfs:label "Work Task"@en ;
    rdfs:comment """系统自动生成或人工创建的业务作业任务，贯穿任务生成→确认→执行→复核→闭环全生命周期。
以商品临期打折场景为例：系统检测到商品临期，自动生成打折执行任务，推荐折扣幅度，店长确认或系统自动确认，员工执行IF枪扫描并打印价签，POS数据回传后店长复核闭环。
状态流转：待确认→已确认→执行中→已完成/已取消/已超时。"""@zh-CN .

# --- WorkTask 数据类型属性（DatatypeProperty）---

# 任务编号（唯一标识，主键）
so:taskId a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:string ;
    rdfs:label "任务编号"@zh-CN ;
    rdfs:label "task ID"@en ;
    rdfs:comment "任务的唯一标识符，如 T-20260419-0001"@zh-CN .

# 任务类型（枚举）
so:taskType a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:TaskType ;
    rdfs:label "任务类型"@zh-CN ;
    rdfs:label "task type"@en ;
    rdfs:comment "任务类型枚举，如 TaskTypeDiscountExecute（打折执行任务）"@zh-CN .

# 任务状态（枚举）
so:taskStatus a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:TaskStatus ;
    rdfs:label "任务状态"@zh-CN ;
    rdfs:label "task status"@en ;
    rdfs:comment "任务状态枚举：待确认→已确认→执行中→已完成/已取消/已超时"@zh-CN .

# 任务优先级（枚举）
so:taskPriority a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:TaskPriority ;
    rdfs:label "任务优先级"@zh-CN ;
    rdfs:label "task priority"@en ;
    rdfs:comment "任务优先级：高/中/低，影响任务排序和提醒"@zh-CN .

# 创建时间
so:createdAt a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:dateTime ;
    rdfs:label "创建时间"@zh-CN ;
    rdfs:label "created at"@en ;
    rdfs:comment "任务被创建的时间戳"@zh-CN .

# 截止时间
so:dueTime a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:dateTime ;
    rdfs:label "截止时间"@zh-CN ;
    rdfs:label "due time"@en ;
    rdfs:comment "任务必须完成的截止时间"@zh-CN .

# 实际完成时间
so:completedAt a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:dateTime ;
    rdfs:label "完成时间"@zh-CN ;
    rdfs:label "completed at"@en ;
    rdfs:comment "任务实际完成的时间戳"@zh-CN .

# 是否需要人工确认
so:requiresConfirmation a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:boolean ;
    rdfs:label "是否需人工确认"@zh-CN ;
    rdfs:label "requires human confirmation"@en ;
    rdfs:comment "true=需店长人工审批，false=系统自动确认无需人工"@zh-CN .

# 是否自动确认模式
so:autoConfirm a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:boolean ;
    rdfs:label "自动确认模式"@zh-CN ;
    rdfs:label "auto confirm mode"@en ;
    rdfs:comment "true=无需人工操作，店长确认和执行可自动完成；false=需店长手工操作"@zh-CN .

# 触发原因（触发规则编号或事件描述）
so:triggerReason a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:string ;
    rdfs:label "触发原因"@zh-CN ;
    rdfs:label "trigger reason"@en ;
    rdfs:comment "触发任务的规则编号或事件描述，如 R-201（库存临期规则）"@zh-CN .

# 推荐折扣幅度
so:recommendedDiscountRate a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:decimal ;
    rdfs:label "推荐折扣幅度"@zh-CN ;
    rdfs:label "recommended discount rate"@en ;
    rdfs:comment "系统推理得出的推荐折扣，如3折、5折。参考保质期剩余天数和库存数量"@zh-CN .

# 推荐理由
so:recommendedReason a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:string ;
    rdfs:label "推荐理由"@zh-CN ;
    rdfs:label "recommended reason"@en ;
    rdfs:comment "系统推理依据，如保质期剩1天且库存200件，建议打3折"@zh-CN .

# 确认折扣幅度
so:confirmedDiscountRate a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:decimal ;
    rdfs:label "确认折扣幅度"@zh-CN ;
    rdfs:label "confirmed discount rate"@en ;
    rdfs:comment "店长最终确认的折扣幅度，或系统自动确认的值"@zh-CN .

# 实际执行折扣
so:executedDiscountRate a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:decimal ;
    rdfs:label "实际执行折扣"@zh-CN ;
    rdfs:label "executed discount rate"@en ;
    rdfs:comment "员工实际执行时的折扣，可能与确认折扣不同（如现场调整）"@zh-CN .

# IF枪扫描条码
so:scanBarcode a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:string ;
    rdfs:label "IF枪扫描条码"@zh-CN ;
    rdfs:label "IF gun scan barcode"@en ;
    rdfs:comment "员工使用IF枪扫描的商品条码，用于追溯验证"@zh-CN .

# 价格标签已打印
so:priceLabelPrinted a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:boolean ;
    rdfs:label "价格标签已打印"@zh-CN ;
    rdfs:label "price label printed"@en ;
    rdfs:comment "员工是否已打印新的价格标签并贴在商品上"@zh-CN .

# 任务备注
so:taskNotes a owl:DatatypeProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range xsd:string ;
    rdfs:label "任务备注"@zh-CN ;
    rdfs:label "task notes"@en ;
    rdfs:comment "任务相关备注信息"@zh-CN .

# --- WorkTask 对象属性（Link Type）---

# 触发事件
so:triggeredByEvent a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Event ;
    rdfs:label "触发事件"@zh-CN ;
    rdfs:label "triggered by event"@en ;
    rdfs:comment "触发本次任务的本体事件，如 InventoryExcessEvent（库存过剩事件）"@zh-CN .

# 触发库存事件（库存临期专属）
so:triggeredByInventoryEvent a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:InventoryEvent ;
    rdfs:label "触发库存事件"@zh-CN ;
    rdfs:label "triggered by inventory event"@en ;
    rdfs:comment "触发打折任务的库存临期事件，关联商品和剩余保质期信息"@zh-CN .

# 任务门店
so:taskStore a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Store ;
    rdfs:label "任务门店"@zh-CN ;
    rdfs:label "task store"@en ;
    rdfs:comment "任务执行的目标门店"@zh-CN .

# 分配对象
so:assignedTo a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Employee ;
    rdfs:label "分配对象"@zh-CN ;
    rdfs:label "assigned to"@en ;
    rdfs:comment "被指定执行该任务的员工"@zh-CN .

# 执行人
so:executedBy a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Employee ;
    rdfs:label "执行人"@zh-CN ;
    rdfs:label "executed by"@en ;
    rdfs:comment "实际完成任务签字确认的员工，可能与 assignedTo 不同"@zh-CN .

# 确认人
so:confirmedBy a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Employee ;
    rdfs:label "确认人"@zh-CN ;
    rdfs:label "confirmed by"@en ;
    rdfs:comment "审批确认打折幅度的店长"@zh-CN .

# 关联商品
so:relatedSKU a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:SKU ;
    rdfs:label "关联商品"@zh-CN ;
    rdfs:label "related SKU"@en ;
    rdfs:comment "打折任务关联的商品SKU"@zh-CN .

# 关联促销
so:relatedPromotion a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Promotion ;
    rdfs:label "关联促销"@zh-CN ;
    rdfs:label "related promotion"@en ;
    rdfs:comment "打折任务关联的促销活动"@zh-CN .

# 关联检查清单
so:hasChecklist a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:WorkTaskCheckItem ;
    rdfs:label "检查清单"@zh-CN ;
    rdfs:label "has checklist"@en ;
    rdfs:comment "任务执行前的检查清单，如商品保质期核查、陈列检查"@zh-CN .

# 关联执行结果
so:hasResult a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:WorkTaskResult ;
    rdfs:label "执行结果"@zh-CN ;
    rdfs:label "has result"@en ;
    rdfs:comment "员工执行完成后的结果记录，包含POS出清数据"@zh-CN .

# 关联复核记录
so:hasReview a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:WorkTaskReview ;
    rdfs:label "复核记录"@zh-CN ;
    rdfs:label "has review"@en ;
    rdfs:comment "店长复核后的结论记录"@zh-CN .

# 下一任务
so:nextTask a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:WorkTask ;
    rdfs:label "下一任务"@zh-CN ;
    rdfs:label "next task"@en ;
    rdfs:comment "复核通过后触发的后续任务，如整改任务"@zh-CN .

# ============================================================
# 第二部分：WorkTaskCheckItem Object Type（检查清单项）
# ============================================================

so:WorkTaskCheckItem a owl:Class ;
    rdfs:label "检查项"@zh-CN ;
    rdfs:label "Task Check Item"@en ;
    rdfs:comment """任务检查清单中的单个检查项。
例如打折场景的检查项包括：商品保质期核查、价格标签核查、陈列位置核查等。
每个检查项可记录检查结果（合格/不合格/不适用）和照片证据。"""@zh-CN .

so:checkItemSequence a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskCheckItem ;
    rdfs:range xsd:integer ;
    rdfs:label "检查项序号"@zh-CN ;
    rdfs:label "check item sequence"@en ;
    rdfs:comment "检查项在清单中的顺序号"@zh-CN .

so:checkItemName a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskCheckItem ;
    rdfs:range xsd:string ;
    rdfs:label "检查项名称"@zh-CN ;
    rdfs:label "check item name"@en ;
    rdfs:comment "检查项的具体描述，如商品保质期是否≥5天"@zh-CN .

so:checkItemResult a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskCheckItem ;
    rdfs:range so:CheckResult ;
    rdfs:label "检查结果"@zh-CN ;
    rdfs:label "check result"@en ;
    rdfs:comment "检查结果枚举：合格/不合格/不适用"@zh-CN .

so:checkItemNotes a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskCheckItem ;
    rdfs:range xsd:string ;
    rdfs:label "检查备注"@zh-CN ;
    rdfs:label "check item notes"@en ;
    rdfs:comment "检查项的具体情况说明和拍照记录"@zh-CN .

so:checkPhoto a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskCheckItem ;
    rdfs:range xsd:anyURI ;
    rdfs:label "检查照片"@zh-CN ;
    rdfs:label "check photo URL"@en ;
    rdfs:comment "检查项的现场照片URI"@zh-CN .

# 所属任务（逆属性）
so:checklistOfTask a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskCheckItem ;
    rdfs:range so:WorkTask ;
    rdfs:label "所属任务"@zh-CN ;
    rdfs:label "checklist of task"@en ;
    owl:inverseOf so:hasChecklist ;
    rdfs:comment "检查项所属的任务，逆属性"@zh-CN .

# ============================================================
# 第三部分：WorkTaskResult Object Type（执行结果）
# ============================================================

so:WorkTaskResult a owl:Class ;
    rdfs:label "执行结果"@zh-CN ;
    rdfs:label "Work Task Result"@en ;
    rdfs:comment """员工完成任务后提交的执行结果记录。
包含检查项结果、POS出清数据（出清率、销售数量、销售额）等核心闭环数据。
Result 实体通过 hasResult 关联到 WorkTask。"""@zh-CN .

so:resultId a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:string ;
    rdfs:label "结果编号"@zh-CN ;
    rdfs:label "result ID"@en ;
    rdfs:comment "执行结果的唯一标识，如 R-TASK-20260419-0001"@zh-CN .

so:submissionTime a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:dateTime ;
    rdfs:label "提交时间"@zh-CN ;
    rdfs:label "submission time"@en ;
    rdfs:comment "员工提交结果的时间戳"@zh-CN .

so:resultStatus a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range so:ResultStatus ;
    rdfs:label "结果状态"@zh-CN ;
    rdfs:label "result status"@en ;
    rdfs:comment "结果状态枚举：已提交/已确认/已驳回"@zh-CN .

so:overallResult a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range so:DiscountResult ;
    rdfs:label "综合结论"@zh-CN ;
    rdfs:label "overall result"@en ;
    rdfs:comment "打折场景的综合结论：打折成功/部分处理/无法处理"@zh-CN .

so:resultNotes a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:string ;
    rdfs:label "结果备注"@zh-CN ;
    rdfs:label "result notes"@en ;
    rdfs:comment "执行结果备注说明"@zh-CN .

# 原库存数量（打折前的库存总数）
so:originalInventoryQty a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:integer ;
    rdfs:label "原库存数量"@zh-CN ;
    rdfs:label "original inventory quantity"@en ;
    rdfs:comment "打折任务开始时的商品库存总数，用于计算出清率"@zh-CN .

# 累计销售数量（从POS获取的打折后卖出数量）
so:soldQty a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:integer ;
    rdfs:label "累计销售数量"@zh-CN ;
    rdfs:label "sold quantity"@en ;
    rdfs:comment "从POS系统获取的打折后的累计销售数量"@zh-CN .

# 剩余库存
so:remainingQty a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:integer ;
    rdfs:label "剩余库存"@zh-CN ;
    rdfs:label "remaining quantity"@en ;
    rdfs:comment "打折后还未卖出的商品数量"@zh-CN .

# 出清率
so:clearanceRate a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "出清率"@zh-CN ;
    rdfs:label "clearance rate"@en ;
    rdfs:comment "出清率 = 累计销售数量 ÷ 原库存数量 × 100%，如 0.75 表示75%出清率"@zh-CN .

# 打折销售额
so:discountedRevenue a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "打折销售额"@zh-CN ;
    rdfs:label "discounted revenue"@en ;
    rdfs:comment "打折后的实际销售收入金额"@zh-CN .

# POS交易流水号
so:posTransactionId a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:string ;
    rdfs:label "POS交易流水号"@zh-CN ;
    rdfs:label "POS transaction ID"@en ;
    rdfs:comment "用于追溯POS系统的交易流水号"@zh-CN .

# POS数据获取时间
so:posFetchedAt a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range xsd:dateTime ;
    rdfs:label "POS数据获取时间"@zh-CN ;
    rdfs:label "POS data fetched at"@en ;
    rdfs:comment "从POS系统拉取销售数据的时间戳"@zh-CN .

# 提交人
so:submittedBy a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range so:Employee ;
    rdfs:label "提交人"@zh-CN ;
    rdfs:label "submitted by"@en ;
    rdfs:comment "提交执行结果的员工"@zh-CN .

# 关联任务（逆属性）
so:resultOfTask a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range so:WorkTask ;
    rdfs:label "关联任务"@zh-CN ;
    rdfs:label "result of task"@en ;
    owl:inverseOf so:hasResult ;
    rdfs:comment "结果所属的任务，逆属性"@zh-CN .

# 包含检查结果明细
so:hasCheckResult a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskResult ;
    rdfs:range so:WorkTaskCheckItem ;
    rdfs:label "检查结果明细"@zh-CN ;
    rdfs:label "has check result"@en ;
    rdfs:comment "关联本次执行的所有检查项结果"@zh-CN .

# ============================================================
# 第四部分：WorkTaskReview Object Type（复核记录）
# ============================================================

so:WorkTaskReview a owl:Class ;
    rdfs:label "任务复核"@zh-CN ;
    rdfs:label "Work Task Review"@en ;
    rdfs:comment """店长或区域经理对任务执行结果进行复核的记录。
包含复核结论（通过/整改/驳回）和整改要求。
复核结果触发后续整改任务或闭环归档。"""@zh-CN .

so:reviewId a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range xsd:string ;
    rdfs:label "复核编号"@zh-CN ;
    rdfs:label "review ID"@en ;
    rdfs:comment "复核记录的唯一标识，如 RV-TASK-20260419-0001"@zh-CN .

so:reviewTime a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range xsd:dateTime ;
    rdfs:label "复核时间"@zh-CN ;
    rdfs:label "review time"@en ;
    rdfs:comment "店长复核的时间戳"@zh-CN .

so:reviewStatus a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range so:ReviewStatus ;
    rdfs:label "复核结论"@zh-CN ;
    rdfs:label "review status"@en ;
    rdfs:comment "复核结论枚举：待复核/复核通过/需整改/复核驳回"@zh-CN .

so:reviewComment a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range xsd:string ;
    rdfs:label "复核意见"@zh-CN ;
    rdfs:label "review comment"@en ;
    rdfs:comment "店长的复核意见和具体要求"@zh-CN .

so:rectificationRequired a owl:DatatypeProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range xsd:boolean ;
    rdfs:label "是否需整改"@zh-CN ;
    rdfs:label "rectification required"@en ;
    rdfs:comment "复核结论是否需要发起整改"@zh-CN .

# 复核人
so:reviewedBy a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range so:Employee ;
    rdfs:label "复核人"@zh-CN ;
    rdfs:label "reviewed by"@en ;
    rdfs:comment "执行复核的店长或区域经理"@zh-CN .

# 关联任务（逆属性）
so:reviewOfTask a owl:ObjectProperty ;
    rdfs:domain so:WorkTaskReview ;
    rdfs:range so:WorkTask ;
    rdfs:label "关联任务"@zh-CN ;
    rdfs:label "review of task"@en ;
    owl:inverseOf so:hasReview ;
    rdfs:comment "复核所属的任务，逆属性"@zh-CN .

