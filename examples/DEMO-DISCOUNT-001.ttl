# ============================================================
# 门店本体论示例：商品临期打折完整业务流程实例
# ============================================================
# 场景：商品"蒙牛特仑苏有机纯牛奶250ml"临期，系统自动生成打折任务
# 完整闭环：创建 → 店长确认 → 员工执行 → POS数据回传 → 店长复核 → 闭环
# ============================================================

@prefix so:   <https://store-ontology.example.com/retail#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

@base <https://store-ontology.example.com/retail/instances> .

# ============================================================
# 第一段：系统自动创建 WorkTask（库存临期事件触发）
# ============================================================
# 时间：2026-04-19 08:30:00
# 触发规则：R-201（保质期≤3天 且 库存≥50件 → 自动生成打折任务）
# 商品：蒙牛特仑苏有机纯牛奶250ml，批次LOT-20260401-001
# 门店：家家悦解放路店（STORE-001）
# 系统推理：保质期剩2天，库存200件，推荐打3折

<instance/TASK-20260419-0001> a so:WorkTask ;
    # 基础属性
    so:taskId "TASK-20260419-0001" ;
    so:taskType so:TaskTypeDiscountExecute ;
    so:taskStatus so:TaskPending ;
    so:taskPriority so:PriorityHigh ;
    so:createdAt "2026-04-19T08:30:00"^^xsd:dateTime ;
    so:dueTime "2026-04-19T23:59:59"^^xsd:dateTime ;
    so:triggerReason "R-201" ;

    # 系统推理推荐
    so:recommendedDiscountRate "3折"@zh-CN ;
    so:recommendedReason "保质期剩2天（到期2026-04-21），当前库存200件，建议打3折"@zh-CN ;

    # 执行模式
    so:requiresConfirmation true ;
    so:autoConfirm false ;

    # 关联关系
    so:taskStore <instance/STORE-001> ;
    so:relatedSKU <instance/SKU-6903145191234> ;
    so:triggeredByInventoryEvent <instance/EVENT-INV-20260419-0001> ;
    so:hasChecklist <instance/CHECKLIST-001> ;

    # 备注
    so:taskNotes "系统自动生成，规则R-201触发"@zh-CN .

# ------------------------------------------------------------
# 关联的库存临期事件
# ------------------------------------------------------------
<instance/EVENT-INV-20260419-0001> a so:InventoryEvent ;
    so:eventId "EVENT-INV-20260419-0001" ;
    so:eventType so:EventTypeShelfLifeWarning ;
    so:eventTime "2026-04-19T08:30:00"^^xsd:dateTime ;
    so:relatedSKU <instance/SKU-6903145191234> ;
    so:relatedStore <instance/STORE-001> ;
    so:shelfLifeRemainingDays 2 ;
    so:currentInventoryQty 200 ;
    so:expiryDate "2026-04-21"^^xsd:date ;
    so:triggerRuleId "R-201" .

# ------------------------------------------------------------
# 关联门店（占位示例）
# ------------------------------------------------------------
<instance/STORE-001> a so:Store ;
    so:storeId "STORE-001" ;
    rdfs:label "家家悦解放路店"@zh-CN ;
    so:storeName "家家悦解放路店"@zh-CN ;
    so:storeAddress "青岛市市南区解放路88号"@zh-CN .

# ------------------------------------------------------------
# 关联商品SKU（占位示例）
# ------------------------------------------------------------
<instance/SKU-6903145191234> a so:SKU ;
    so:skuId "6903145191234" ;
    rdfs:label "蒙牛特仑苏有机纯牛奶250ml"@zh-CN ;
    so:productName "蒙牛特仑苏有机纯牛奶250ml"@zh-CN ;
    so:barcode "6903145191234" ;
    so:category "液态奶"@zh-CN .

# ------------------------------------------------------------
# 检查清单（员工执行前核查）
# ------------------------------------------------------------
<instance/CHECKLIST-001> a so:WorkTaskCheckItem ;
    so:checkItemSequence 1 ;
    so:checkItemName "商品保质期核查"@zh-CN ;
    so:checkItemResult so:ResultPass ;
    so:checkItemNotes "确认商品保质期剩余2天，符合打折条件"@zh-CN ;
    so:checklistOfTask <instance/TASK-20260419-0001> .

<instance/CHECKLIST-002> a so:WorkTaskCheckItem ;
    so:checkItemSequence 2 ;
    so:checkItemName "价格标签核查"@zh-CN ;
    so:checkItemResult so:ResultPass ;
    so:checkItemNotes "原价签已取下，新价签待打印"@zh-CN ;
    so:checklistOfTask <instance/TASK-20260419-0001> .

<instance/CHECKLIST-003> a so:WorkTaskCheckItem ;
    so:checkItemSequence 3 ;
    so:checkItemName "陈列位置核查"@zh-CN ;
    so:checkItemResult so:ResultPass ;
    so:checkItemNotes "已移至临期商品专区"@zh-CN ;
    so:checklistOfTask <instance/TASK-20260419-0001> .

# ============================================================
# 第二段：店长王五确认打折幅度（2026-04-19 09:15:00）
# ============================================================
# 店长王五审核系统推荐（3折），最终确认5折
# 备注：系统推荐偏低，结合库存量和过往销售数据，5折更有利于出清

<instance/TASK-20260419-0001> a so:WorkTask ;
    so:taskStatus so:TaskConfirmed ;
    so:confirmedDiscountRate "5折"@zh-CN ;
    so:confirmedBy <instance/EMP-WANGWU> ;
    so:taskNotes "店长确认5折，系统推荐3折偏低，结合库存和历史数据调整"@zh-CN .

<instance/EMP-WANGWU> a so:Employee ;
    so:employeeId "EMP-001" ;
    rdfs:label "王五（店长）"@zh-CN ;
    so:employeeName "王五"@zh-CN ;
    so:role so:RoleStoreManager .

# ============================================================
# 第三段：员工李四执行打折（2026-04-19 10:00:00）
# ============================================================
# 员工李四使用IF枪扫描商品条码，打印新价格标签，完成执行

<instance/TASK-20260419-0001> a so:WorkTask ;
    so:taskStatus so:TaskInProgress ;
    so:assignedTo <instance/EMP-LISI> ;
    so:scanBarcode "6903145191234" ;
    so:priceLabelPrinted true ;
    so:executedBy <instance/EMP-LISI> ;
    so:taskNotes "员工李四已扫描商品并打印新价签，商品已上架临期专区"@zh-CN .

<instance/EMP-LISI> a so:Employee ;
    so:employeeId "EMP-002" ;
    rdfs:label "李四（一线员工）"@zh-CN ;
    so:employeeName "李四"@zh-CN ;
    so:role so:RoleFrontline .

# ============================================================
# 第四段：员工提交执行结果 + POS数据回传（2026-04-19 22:00:00）
# ============================================================
# 当日营业结束，POS系统回传销售数据：
# - 原库存：200件
# - 当日销售：152件
# - 剩余库存：48件
# - 出清率：76%（152÷200）
# - 销售额：￥1216.00

<instance/RESULT-TASK-20260419-0001> a so:WorkTaskResult ;
    so:resultId "RESULT-TASK-20260419-0001" ;
    so:resultStatus so:ResultSubmitted ;
    so:submissionTime "2026-04-19T22:00:00"^^xsd:dateTime ;
    so:submittedBy <instance/EMP-LISI> ;

    # POS数据
    so:originalInventoryQty 200 ;
    so:soldQty 152 ;
    so:remainingQty 48 ;
    so:clearanceRate "0.76"^^xsd:decimal ;
    so:discountedRevenue "1216.00"^^xsd:decimal ;
    so:posTransactionId "TXN-POS-001-20260419-215803" ;
    so:posFetchedAt "2026-04-19T22:00:00"^^xsd:dateTime ;

    # 综合结论
    so:overallResult so:DiscountSuccess ;

    # 关联任务
    so:resultOfTask <instance/TASK-20260419-0001> ;

    # 备注
    so:resultNotes "当日临期专区销售152件，出清率76%，基本完成出清目标"@zh-CN .

<instance/TASK-20260419-0001> a so:WorkTask ;
    so:taskStatus so:TaskCompleted ;
    so:completedAt "2026-04-19T22:00:00"^^xsd:dateTime ;
    so:executedDiscountRate "5折"@zh-CN ;
    so:hasResult <instance/RESULT-TASK-20260419-0001> .

# ============================================================
# 第五段：店长王五复核（2026-04-20 08:30:00）
# ============================================================
# 店长王五审核昨日执行数据：出清率76%，无异常
# 复核结论：通过，无需整改

<instance/REVIEW-TASK-20260419-0001> a so:WorkTaskReview ;
    so:reviewId "REVIEW-TASK-20260419-0001" ;
    so:reviewTime "2026-04-20T08:30:00"^^xsd:dateTime ;
    so:reviewStatus so:ReviewPassed ;
    so:reviewedBy <instance/EMP-WANGWU> ;
    so:rectificationRequired false ;
    so:reviewComment "出清率76%达标，执行过程符合规范，复核通过。"@zh-CN ;
    so:reviewOfTask <instance/TASK-20260419-0001> .

<instance/TASK-20260419-0001> a so:WorkTask ;
    so:hasReview <instance/REVIEW-TASK-20260419-0001> .

# ============================================================
# 第六段：执行后员工消息通知（SideEffect 回显）
# ============================================================
# 复核通过后，系统自动通知执行员工李四复核结果
# 通知内容："打折任务【TASK-20260419-0001】复核结果：通过，意见：出清率76%达标，执行过程符合规范，复核通过。"

########## END OF DEMO-DISCOUNT-001 ##########
