so:CurrentActor a owl:NamedIndividual ;
    rdfs:label "当前操作者"@zh-CN ;
    rdfs:label "Current Actor"@en ;
    rdfs:comment "指向当前登录用户/员工的系统引用"@zh-CN .

so:CurrentTimestamp a owl:NamedIndividual ;
    rdfs:label "当前时间戳"@zh-CN ;
    rdfs:label "Current Timestamp"@en ;
    rdfs:comment "指向当前时间的系统引用"@zh-CN .

so:POSSystem a owl:NamedIndividual ;
    rdfs:label "POS系统"@zh-CN ;
    rdfs:label "Point of Sale System"@en ;
    rdfs:comment "POS销售系统数据源"@zh-CN .

so:LogicCurrentShiftEmployee a owl:NamedIndividual ;
    rdfs:label "当前班次员工逻辑"@zh-CN ;
    rdfs:label "Current Shift Employee Logic"@en ;
    rdfs:comment "系统默认逻辑：返回当前班次值班员工"@zh-CN .

so:RuleTypeValidation a owl:NamedIndividual ;
    rdfs:label "校验规则"@zh-CN ;
    rdfs:label "Validation Rule"@en ;
    rdfs:subClassOf so:Rule .

so:Rule a owl:Class ;
    rdfs:label "规则"@zh-CN ;
    rdfs:comment "Action参数校验或业务规则"@zh-CN .

