so:hasInventoryEvent a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:InventoryEvent ;
    rdfs:label "库存事件记录"@zh-CN ;
    rdfs:label "Has Inventory Event"@en .

so:atStore a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:Store ;
    rdfs:label "所属门店"@zh-CN ;
    rdfs:label "At Store"@en .

# --- InventoryEventType 枚举 ---
so:InventoryEventType a owl:Class ;
    rdfs:label "库存事件类型"@zh-CN ;
    rdfs:comment "库存事件类型枚举"@zh-CN .

so:InventoryEventShelfLifeWarning a owl:NamedIndividual ;
    rdfs:label "临期预警"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:InventoryEventShelfLifeCritical a owl:NamedIndividual ;
    rdfs:label "临期紧急"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:InventoryEventShelfLifeExpired a owl:NamedIndividual ;
    rdfs:label "已过期"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:InventoryEventClearanceStart a owl:NamedIndividual ;
    rdfs:label "出清开始"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:InventoryEventClearanceComplete a owl:NamedIndividual ;
    rdfs:label "出清完成"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

# --- 补充已有 DatatypeProperty 的逆属性 ---
so:relatedTask a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:WorkTask ;
    rdfs:label "关联任务"@zh-CN ;
    rdfs:label "Related Task"@en .

# --- Promotion 占位符（补充基础属性）---
so:Promotion a owl:Class ;
