# Store Ontology Backend - Environment Configuration
# Copy to .env (project root) and fill in your real key.

# Qwen / MiniMax OpenAI-compatible API
QWEN_API_KEY=
QWEN_BASE_URL=https://api.minimaxi.com/v1
QWEN_MODEL=MiniMax-M2.7-highspeed

# v2 认证（设计文档 §2.1/§5 WP2）
# JWT 签名密钥（生产必填，随机长字符串；不进 git）
JWT_SECRET=
# Access token 有效期（秒），默认 7200=2h
JWT_ACCESS_TTL=7200
# Refresh token 有效期（秒），默认 604800=7d
JWT_REFRESH_TTL=604800
# 各 workspace 首次启动种入的初始 admin 密码（默认 admin123，生产应覆盖）
INITIAL_ADMIN_PASSWORD=
