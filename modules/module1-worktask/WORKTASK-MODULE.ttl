# ============================================================
# 第六部分补充：ActionType 元属性声明
# ============================================================
# 本体声明所有用于描述 ActionType 结构的元属性（Meta-Property）
# 这些 ObjectProperty 是 ActionType 语义层的构建基础
# ============================================================

# --- Action 操作要素 ---
so:targetObjectType a owl:ObjectProperty ;
    rdfs:label "目标对象类型"@zh-CN ;
    rdfs:label "Target Object Type"@en ;
    rdfs:comment "Action作用于哪个ObjectType（如WorkTask）"@zh-CN .

so:actionOperation a owl:ObjectProperty ;
    rdfs:label "操作类型"@zh-CN ;
    rdfs:label "Action Operation"@en ;
    rdfs:comment "Action的操作类型：Create/Modify/Delete"@zh-CN .

so:hasParameter a owl:ObjectProperty ;
    rdfs:label "Action参数"@zh-CN ;
    rdfs:label "Action Parameter"@en ;
    rdfs:comment "Action的输入参数定义"@zh-CN .

so:writesProperty a owl:ObjectProperty ;
    rdfs:label "写入属性"@zh-CN ;
    rdfs:label "Writes Property"@en ;
    rdfs:comment "Action执行时修改的目标属性"@zh-CN .

so:writesLink a owl:ObjectProperty ;
    rdfs:label "写入链接"@zh-CN ;
    rdfs:label "Writes Link"@en ;
    rdfs:comment "Action执行时创建/修改的目标链接（指向子对象）"@zh-CN .

so:hasSideEffect a owl:ObjectProperty ;
    rdfs:label "副作用"@zh-CN ;
    rdfs:label "Side Effect"@en ;
    rdfs:comment "Action执行后的附加效果（通知/链式Action/用户提示）"@zh-CN .

so:submissionCriteria a owl:ObjectProperty ;
    rdfs:label "提交条件"@zh-CN ;
    rdfs:label "Submission Criteria"@en ;
    rdfs:comment "Action允许执行的前置条件"@zh-CN .

so:chainedAction a owl:ObjectProperty ;
    rdfs:label "链式Action"@zh-CN ;
    rdfs:label "Chained Action"@en ;
    rdfs:comment "副作用触发：自动执行下一个Action"@zh-CN .

# --- WriteProp 详情 ---
so:targetProperty a owl:ObjectProperty ;
    rdfs:label "目标属性"@zh-CN ;
    rdfs:label "Target Property"@en ;
    rdfs:comment "WriteProp要写入的目标属性"@zh-CN .

so:writeOperation a owl:ObjectProperty ;
    rdfs:label "写入操作类型"@zh-CN ;
    rdfs:label "Write Operation"@en ;
    rdfs:comment "写入操作类型：Set Value / Append / Create Object / Conditional"@zh-CN .

so:writeValue a owl:ObjectProperty ;
    rdfs:label "固定写入值"@zh-CN ;
    rdfs:label "Fixed Write Value"@en ;
    rdfs:comment "直接写入的固定值（如枚举值、固定字符串）"@zh-CN .

so:writeValueParam a owl:ObjectProperty ;
    rdfs:label "参数写入值"@zh-CN ;
    rdfs:label "Parameter Write Value"@en ;
    rdfs:comment "写入的值来自Action的某个输入参数"@zh-CN .

# --- 条件写入 ---
so:conditionWrite a owl:ObjectProperty ;
    rdfs:label "条件写入分支"@zh-CN ;
    rdfs:label "Conditional Write Branch"@en ;
    rdfs:comment "条件写入的不同分支（when条件成立时执行）"@zh-CN .

so:conditionParam a owl:ObjectProperty ;
    rdfs:label "条件参数"@zh-CN ;
    rdfs:label "Condition Parameter"@en ;
    rdfs:comment "条件判断所引用的参数"@zh-CN .

so:conditionValue a owl:ObjectProperty ;
    rdfs:label "条件值"@zh-CN ;
    rdfs:label "Condition Value"@en ;
    rdfs:comment "条件比较的目标值"@zh-CN .

# --- 提交条件详情 ---
so:criteriaProperty a owl:ObjectProperty ;
    rdfs:label "条件属性"@zh-CN ;
    rdfs:label "Criteria Property"@en ;
    rdfs:comment "提交条件所检查的对象属性"@zh-CN .

so:criteriaOperator a owl:ObjectProperty ;
    rdfs:label "条件运算符"@zh-CN ;
    rdfs:label "Criteria Operator"@en ;
    rdfs:comment "条件比较运算符：Equals / NotNull / LinkExists"@zh-CN .

so:criteriaValue a owl:ObjectProperty ;
    rdfs:label "条件目标值"@zh-CN ;
    rdfs:label "Criteria Value"@en ;
    rdfs:comment "条件比较的目标值（如枚举值）"@zh-CN .

# --- 副作用详情 ---
so:sideEffectType a owl:ObjectProperty ;
    rdfs:label "副作用类型"@zh-CN ;
    rdfs:label "Side Effect Type"@en ;
    rdfs:comment "副作用类型：Notification / ChainAction / UserPrompt"@zh-CN .

so:notificationTemplate a owl:DatatypeProperty ;
    rdfs:label "通知模板"@zh-CN ;
    rdfs:label "Notification Template"@en ;
    rdfs:comment "通知消息模板，支持占位符替换"@zh-CN .

so:promptMessage a owl:DatatypeProperty ;
    rdfs:label "提示消息"@zh-CN ;
    rdfs:label "Prompt Message"@en ;
    rdfs:comment "用户提示内容"@zh-CN .

so:writeLinkProperty a owl:ObjectProperty ;
    rdfs:label "写入链接属性"@zh-CN ;
    rdfs:label "Write Link Property"@en ;
    rdfs:comment "WriteLink要创建链接的属性（如hasResult）"@zh-CN .

so:autoPopulateProperties a owl:ObjectProperty ;
    rdfs:label "自动填充属性列表"@zh-CN ;
    rdfs:label "Auto Populate Properties"@en ;
    rdfs:comment "自动填充的目标属性列表"@zh-CN .

so:populatesProperty a owl:ObjectProperty ;
    rdfs:label "填充属性"@zh-CN ;
    rdfs:label "Populates Property"@en ;
    rdfs:comment "自动填充的单个目标属性"@zh-CN .

so:dataMapping a owl:DatatypeProperty ;
    rdfs:label "数据映射"@zh-CN ;
    rdfs:label "Data Mapping"@en ;
    rdfs:comment "外部数据源字段与本体属性的映射关系"@zh-CN .

so:derivedFrom a owl:ObjectProperty ;
    rdfs:label "派生来源"@zh-CN ;
    rdfs:label "Derived From"@en ;
    rdfs:comment "属性值从哪个参数派生而来"@zh-CN .

so:derivationLogic a owl:DatatypeProperty ;
    rdfs:label "派生逻辑"@zh-CN ;
    rdfs:label "Derivation Logic"@en ;
    rdfs:comment "属性值派生的业务逻辑描述"@zh-CN .

so:autoIDPrefix a owl:DatatypeProperty ;
    rdfs:label "自动ID前缀"@zh-CN ;
    rdfs:label "Auto ID Prefix"@en ;
    rdfs:comment "自动生成ID的前缀（如REV-、TASK-）"@zh-CN .

so:autoIDTimestamp a owl:DatatypeProperty ;
    rdfs:label "自动ID时间戳"@zh-CN ;
    rdfs:label "Auto ID Timestamp"@en ;
    rdfs:comment "自动生成ID是否包含时间戳"@zh-CN .

# --- Action 参数定义 ---
so:paramSource a owl:ObjectProperty ;
    rdfs:label "参数来源"@zh-CN ;
    rdfs:label "Parameter Source"@en ;
    rdfs:comment "参数值来源：UserInput / SystemDefault / Derived"@zh-CN .

so:paramObjectType a owl:ObjectProperty ;
    rdfs:label "参数对象类型"@zh-CN ;
    rdfs:label "Parameter Object Type"@en ;
    rdfs:comment "参数引用的对象类型（如Store、SKU）"@zh-CN .

so:paramDataType a owl:ObjectProperty ;
    rdfs:label "参数数据类型"@zh-CN ;
    rdfs:label "Parameter Data Type"@en ;
    rdfs:comment "参数值的XSD数据类型"@zh-CN .

so:paramRequired a owl:DatatypeProperty ;
    rdfs:label "参数是否必填"@zh-CN ;
    rdfs:label "Parameter Required"@en ;
    rdfs:comment "参数是否为必填项（true/false）"@zh-CN .

so:paramOptions a owl:ObjectProperty ;
    rdfs:label "参数选项"@zh-CN ;
    rdfs:label "Parameter Options"@en ;
    rdfs:comment "枚举型参数的可选值列表"@zh-CN .

so:paramDefaultValue a owl:DatatypeProperty ;
    rdfs:label "参数默认值"@zh-CN ;
    rdfs:label "Parameter Default Value"@en ;
    rdfs:comment "参数的默认值（字面量）"@zh-CN .

so:paramDefaultValueParam a owl:ObjectProperty ;
    rdfs:label "参数默认值引用"@zh-CN ;
    rdfs:label "Parameter Default Value From Param"@en ;
    rdfs:comment "默认值引用另一个参数的值"@zh-CN .

# ============================================================
# 第七部分：Action Type 定义（商品临期打折场景）
# ============================================================
# Palantir Foundry Action Type 核心要素：
#   - targetObjectType : 作用于哪个 Object Type
#   - actionOperation  : 操作类型（CREATE / MODIFY / DELETE）
#   - parameters       : 输入参数（来自对象属性或用户输入）
#   - edits           : 执行时修改哪些属性/链接
#   - submissionCriteria : 提交条件（什么情况下允许执行）
#   - sideEffects     : 副作用（通知、Webhook、自动化）
#
# 本体论实现：用 OWL Class 表示 Action Type，用 ObjectProperty
# 表示参数关系，用 owl:Restriction 表示提交条件
# ============================================================

# ------------------------------------------------------------
# Action Type 1: CreateDiscountTask — 创建打折任务
# ------------------------------------------------------------
# 触发时机：库存事件检测到商品临期，由系统或店长手工创建
# 作用于：WorkTask 对象（CREATE 新建）
# 输入参数：门店、商品SKU、触发原因
# 自动写入：taskType=TaskTypeDiscountExecute, taskStatus=TaskPending,
#           requiresConfirmation, triggerReason, recommendedDiscountRate,
#           recommendedReason

so:CreateDiscountTask a owl:Class ;
    rdfs:label "创建打折任务"@zh-CN ;
    rdfs:label "Create Discount Task"@en ;
    rdfs:comment "商品临期时创建打折执行任务。触发时机：库存事件检测临期或店长手工创建"@zh-CN ;
    so:targetObjectType so:WorkTask ;
    so:actionOperation so:ActionOperationCreate ;
    so:hasParameter so:ParamCreateTaskStore ;
    so:hasParameter so:ParamCreateTaskSKU ;
    so:hasParameter so:ParamCreateTaskTriggerReason ;
    so:hasParameter so:ParamCreateRecommendedDiscountRate ;
    so:hasParameter so:ParamCreateRecommendedReason ;
    so:hasParameter so:ParamCreateRequiresConfirmation ;
    so:writesProperty so:WritePropTaskType ;
    so:writesProperty so:WritePropTaskStatus ;
    so:writesProperty so:WritePropTriggerReason ;
    so:writesProperty so:WritePropRecommendedDiscountRate ;
    so:writesProperty so:WritePropRecommendedReason ;
    so:writesProperty so:WritePropRequiresConfirmation ;
    so:hasSideEffect so:SideEffectNotifyStoreManagerOnCreate .

so:ParamCreateTaskStore a owl:Class ;
    rdfs:label "任务归属门店"@zh-CN ;
    rdfs:label "Store"@en ;
    rdfs:comment "打折任务归属的门店"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramObjectType so:Store ;
    so:paramRequired true .

so:ParamCreateTaskSKU a owl:Class ;
    rdfs:label "任务关联商品"@zh-CN ;
    rdfs:label "Related SKU"@en ;
    rdfs:comment "打折任务关联的商品SKU"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramObjectType so:SKU ;
    so:paramRequired true .

so:ParamCreateTaskTriggerReason a owl:Class ;
    rdfs:label "触发原因"@zh-CN ;
    rdfs:label "Trigger Reason"@en ;
    rdfs:comment "触发打折任务的原因描述（如：保质期剩余3天）"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired true .

so:ParamCreateRecommendedDiscountRate a owl:Class ;
    rdfs:label "推荐打折幅度"@zh-CN ;
    rdfs:label "Recommended Discount Rate"@en ;
    rdfs:comment "系统推理的推荐打折幅度（如：7折）"@zh-CN ;
    so:paramSource so:ParameterSourceSystemDefault ;
    so:paramDataType xsd:string ;
    so:paramRequired false ;
    so:paramDefaultValue "7折"@zh-CN .

so:ParamCreateRecommendedReason a owl:Class ;
    rdfs:label "推荐理由"@zh-CN ;
    rdfs:label "Recommended Reason"@en ;
    rdfs:comment "系统推理推荐打折幅度的理由（保质期+库存量综合）"@zh-CN ;
    so:paramSource so:ParameterSourceSystemDefault ;
    so:paramDataType xsd:string ;
    so:paramRequired false .

so:ParamCreateRequiresConfirmation a owl:Class ;
    rdfs:label "需店长确认"@zh-CN ;
    rdfs:label "Requires Manager Confirmation"@en ;
    rdfs:comment "打折幅度是否需要店长手工确认（true=需确认，false=系统自动确认）"@zh-CN ;
    so:paramSource so:ParameterSourceSystemDefault ;
    so:paramDataType xsd:boolean ;
    so:paramRequired false ;
    so:paramDefaultValue "true"^^xsd:boolean .

so:WritePropTaskType a owl:Class ;
    rdfs:label "写入：任务类型"@zh-CN ;
    rdfs:comment "Action执行时写入taskType=TaskTypeDiscountExecute"@zh-CN ;
    so:targetProperty so:taskType ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:TaskTypeDiscountExecute .

so:WritePropTaskStatus a owl:Class ;
    rdfs:label "写入：任务状态"@zh-CN ;
    rdfs:comment "Action执行时写入taskStatus=TaskPending"@zh-CN ;
    so:targetProperty so:taskStatus ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:TaskPending .

so:WritePropTriggerReason a owl:Class ;
    rdfs:label "写入：触发原因"@zh-CN ;
    rdfs:comment "Action执行时写入triggerReason属性"@zh-CN ;
    so:targetProperty so:triggerReason ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamCreateTaskTriggerReason .

so:WritePropRecommendedDiscountRate a owl:Class ;
    rdfs:label "写入：推荐折扣率"@zh-CN ;
    rdfs:comment "Action执行时写入recommendedDiscountRate属性"@zh-CN ;
    so:targetProperty so:recommendedDiscountRate ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamCreateRecommendedDiscountRate .

so:WritePropRecommendedReason a owl:Class ;
    rdfs:label "写入：推荐理由"@zh-CN ;
    rdfs:comment "Action执行时写入recommendedReason属性"@zh-CN ;
    so:targetProperty so:recommendedReason ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamCreateRecommendedReason .

so:WritePropRequiresConfirmation a owl:Class ;
    rdfs:label "写入：需确认标记"@zh-CN ;
    rdfs:comment "Action执行时写入requiresConfirmation属性"@zh-CN ;
    so:targetProperty so:requiresConfirmation ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamCreateRequiresConfirmation .

so:SideEffectNotifyStoreManagerOnCreate a owl:Class ;
    rdfs:label "副作用：通知店长"@zh-CN ;
    rdfs:comment "打折任务创建后，自动通知店长进行确认"@zh-CN ;
    so:sideEffectType so:SideEffectTypeNotification ;
    so:notifyRole so:RoleStoreManager ;
    so:notificationTemplate "新打折任务已创建，商品【{skuName}】剩余{shelfLifeDays}天保质期，系统推荐{discountRate}折扣，请确认执行"@zh-CN .

# ------------------------------------------------------------
# Action Type 2: ConfirmDiscount — 店长确认打折幅度
# ------------------------------------------------------------
# 触发时机：requiresConfirmation=true时，店长确认最终打折幅度
# 作用于：WorkTask对象（MODIFY修改）
# 输入参数：confirmedDiscountRate（店长决定的折扣）
# 自动写入：taskStatus=TaskConfirmed, confirmedDiscountRate, confirmedBy

so:ConfirmDiscount a owl:Class ;
    rdfs:label "店长确认打折幅度"@zh-CN ;
    rdfs:label "Confirm Discount Rate"@en ;
    rdfs:comment "店长确认打折任务的最终折扣幅度"@zh-CN ;
    so:targetObjectType so:WorkTask ;
    so:actionOperation so:ActionOperationModify ;
    so:submissionCriteria so:CriteriaTaskStatusIsPending ;
    so:submissionCriteria so:CriteriaHasRecommendedDiscountRate ;
    so:hasParameter so:ParamConfirmDiscountRate ;
    so:hasParameter so:ParamConfirmNotes ;
    so:writesProperty so:WritePropTaskStatusConfirmed ;
    so:writesProperty so:WritePropConfirmedDiscountRate ;
    so:writesProperty so:WritePropConfirmedBy ;
    so:hasSideEffect so:SideEffectAutoAssignOnConfirm .

so:CriteriaTaskStatusIsPending a owl:Class ;
    rdfs:label "条件：任务状态为待确认"@zh-CN ;
    rdfs:comment "只有taskStatus=TaskPending的任务才能执行确认操作"@zh-CN ;
    so:criteriaProperty so:taskStatus ;
    so:criteriaOperator so:OperatorEquals ;
    so:criteriaValue so:TaskPending .

so:CriteriaHasRecommendedDiscountRate a owl:Class ;
    rdfs:label "条件：已有推荐折扣率"@zh-CN ;
    rdfs:comment "任务必须已有recommendedDiscountRate才能确认"@zh-CN ;
    so:criteriaProperty so:recommendedDiscountRate ;
    so:criteriaOperator so:OperatorNotNull .

so:ParamConfirmDiscountRate a owl:Class ;
    rdfs:label "确认折扣幅度"@zh-CN ;
    rdfs:label "Confirmed Discount Rate"@en ;
    rdfs:comment "店长确认的最终打折幅度（如：6折、5折）"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired true ;
    so:paramDefaultValueParam so:ParamCreateRecommendedDiscountRate .

so:ParamConfirmNotes a owl:Class ;
    rdfs:label "确认备注"@zh-CN ;
    rdfs:label "Confirmation Notes"@en ;
    rdfs:comment "店长确认时的备注说明"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired false .

so:WritePropTaskStatusConfirmed a owl:Class ;
    rdfs:label "写入：任务状态为已确认"@zh-CN ;
    rdfs:comment "Action执行时写入taskStatus=TaskConfirmed"@zh-CN ;
    so:targetProperty so:taskStatus ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:TaskConfirmed .

so:WritePropConfirmedDiscountRate a owl:Class ;
    rdfs:label "写入：确认的折扣幅度"@zh-CN ;
    rdfs:comment "Action执行时写入confirmedDiscountRate"@zh-CN ;
    so:targetProperty so:confirmedDiscountRate ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamConfirmDiscountRate .

so:WritePropConfirmedBy a owl:Class ;
    rdfs:label "写入：确认人"@zh-CN ;
    rdfs:comment "Action执行时写入confirmedBy（当前用户/店长）"@zh-CN ;
    so:targetProperty so:confirmedBy ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:CurrentActor .

so:SideEffectAutoAssignOnConfirm a owl:Class ;
    rdfs:label "副作用：自动分配执行员工"@zh-CN ;
    rdfs:comment "店长确认后，自动触发AssignAndStart分配执行员工"@zh-CN ;
    so:sideEffectType so:SideEffectTypeChainAction ;
    so:chainedAction so:AssignAndStart .

# ------------------------------------------------------------
# Action Type 3: AssignAndStart — 分配员工+开始执行
# ------------------------------------------------------------
# 触发时机：店长确认后（或autoConfirm=true时系统自动执行）
# 作用于：WorkTask对象（MODIFY修改）
# 输入参数：assignedTo（分配给哪个员工）
# 自动写入：taskStatus=TaskInProgress, assignedTo, dueTime

so:AssignAndStart a owl:Class ;
    rdfs:label "分配员工并开始执行"@zh-CN ;
    rdfs:label "Assign Employee and Start Task"@en ;
    rdfs:comment "将打折任务分配给员工，开始执行。店长确认后或系统自动确认后触发"@zh-CN ;
    so:targetObjectType so:WorkTask ;
    so:actionOperation so:ActionOperationModify ;
    so:submissionCriteria so:CriteriaTaskStatusIsConfirmed ;
    so:hasParameter so:ParamAssignEmployee ;
    so:hasParameter so:ParamAssignDueTime ;
    so:writesProperty so:WritePropTaskStatusInProgress ;
    so:writesProperty so:WritePropAssignedTo ;
    so:writesProperty so:WritePropDueTime ;
    so:hasSideEffect so:SideEffectNotifyEmployeeOnAssign .

so:CriteriaTaskStatusIsConfirmed a owl:Class ;
    rdfs:label "条件：任务状态为已确认"@zh-CN ;
    rdfs:comment "只有taskStatus=TaskConfirmed的任务才能分配执行"@zh-CN ;
    so:criteriaProperty so:taskStatus ;
    so:criteriaOperator so:OperatorEquals ;
    so:criteriaValue so:TaskConfirmed .

so:ParamAssignEmployee a owl:Class ;
    rdfs:label "执行员工"@zh-CN ;
    rdfs:label "Assigned Employee"@en ;
    rdfs:comment "负责执行此打折任务的员工"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramObjectType so:Employee ;
    so:paramRequired true ;
    so:paramDefaultValueParam so:ParamDefaultAssignToRoleEmployee .

so:ParamAssignDueTime a owl:Class ;
    rdfs:label "截止时间"@zh-CN ;
    rdfs:label "Due Time"@en ;
    rdfs:comment "任务完成的截止时间（默认当天营业结束）"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:dateTime ;
    so:paramRequired false ;
    so:paramDefaultValue "当天23:59:59"@zh-CN .

so:ParamDefaultAssignToRoleEmployee a owl:Class ;
    rdfs:label "默认值：值班员工"@zh-CN ;
    rdfs:comment "默认分配给当前班次的值班员工"@zh-CN ;
    so:paramSource so:ParameterSourceSystemDefault ;
    so:paramObjectType so:Employee ;
    so:systemDefaultLogic so:LogicCurrentShiftEmployee .

so:WritePropTaskStatusInProgress a owl:Class ;
    rdfs:label "写入：任务状态为执行中"@zh-CN ;
    rdfs:comment "Action执行时写入taskStatus=TaskInProgress"@zh-CN ;
    so:targetProperty so:taskStatus ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:TaskInProgress .

so:WritePropAssignedTo a owl:Class ;
    rdfs:label "写入：分配员工"@zh-CN ;
    rdfs:comment "Action执行时写入assignedTo"@zh-CN ;
    so:targetProperty so:assignedTo ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamAssignEmployee .

so:WritePropDueTime a owl:Class ;
    rdfs:label "写入：截止时间"@zh-CN ;
    rdfs:comment "Action执行时写入dueTime"@zh-CN ;
    so:targetProperty so:dueTime ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamAssignDueTime .

so:SideEffectNotifyEmployeeOnAssign a owl:Class ;
    rdfs:label "副作用：通知执行员工"@zh-CN ;
    rdfs:comment "任务分配给员工后，自动通知该员工"@zh-CN ;
    so:sideEffectType so:SideEffectTypeNotification ;
    so:notifyRole so:RoleFrontline ;
    so:notificationTemplate "打折任务通知：商品【{skuName}】需执行折扣{discountRate}，请前往门店处理，截止时间{dueTime}"@zh-CN .

# ------------------------------------------------------------
# Action Type 4: ExecuteDiscount — 员工执行（IF枪扫描+打印价签）
# ------------------------------------------------------------
# 触发时机：员工到现场完成操作后，IF枪扫描条码
# 作用于：WorkTask对象（MODIFY修改）
# 输入参数：scanBarcode（IF枪扫描结果）, priceLabelPrinted（是否已打印价签）
# 自动写入：scanBarcode, priceLabelPrinted, taskNotes

so:ExecuteDiscount a owl:Class ;
    rdfs:label "员工执行打折操作"@zh-CN ;
    rdfs:label "Execute Discount (Scan & Print)"@en ;
    rdfs:comment "员工现场执行：用IF枪扫描商品条码，打印并贴上新价格标签"@zh-CN ;
    so:targetObjectType so:WorkTask ;
    so:actionOperation so:ActionOperationModify ;
    so:submissionCriteria so:CriteriaTaskStatusIsInProgress ;
    so:submissionCriteria so:CriteriaAssignedToCurrentEmployee ;
    so:hasParameter so:ParamExecuteScanBarcode ;
    so:hasParameter so:ParamExecutePriceLabelPrinted ;
    so:hasParameter so:ParamExecuteNotes ;
    so:writesProperty so:WritePropScanBarcode ;
    so:writesProperty so:WritePropPriceLabelPrinted ;
    so:writesProperty so:WritePropExecutedBy ;
    so:writesProperty so:WritePropTaskNotesExecute ;
    so:hasSideEffect so:SideEffectPromptSubmitResult .

so:CriteriaTaskStatusIsInProgress a owl:Class ;
    rdfs:label "条件：任务状态为执行中"@zh-CN ;
    rdfs:comment "只有taskStatus=TaskInProgress的任务才能执行操作"@zh-CN ;
    so:criteriaProperty so:taskStatus ;
    so:criteriaOperator so:OperatorEquals ;
    so:criteriaValue so:TaskInProgress .

so:CriteriaAssignedToCurrentEmployee a owl:Class ;
    rdfs:label "条件：当前员工被分配"@zh-CN ;
    rdfs:comment "只有assignedTo=当前登录员工的任务才能执行"@zh-CN ;
    so:criteriaProperty so:assignedTo ;
    so:criteriaOperator so:OperatorEquals ;
    so:criteriaValue so:CurrentActor .

so:ParamExecuteScanBarcode a owl:Class ;
    rdfs:label "IF枪扫描条码"@zh-CN ;
    rdfs:label "Scanned Barcode"@en ;
    rdfs:comment "员工用IF枪扫描商品条码，系统校验与任务商品一致"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired true ;
    so:validationRule so:RuleBarcodeMustMatchSKU .

so:ParamExecutePriceLabelPrinted a owl:Class ;
    rdfs:label "已打印价格标签"@zh-CN ;
    rdfs:label "Price Label Printed"@en ;
    rdfs:comment "员工确认已在商品上贴上新价格标签"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:boolean ;
    so:paramRequired true ;
    so:paramDefaultValue "true"^^xsd:boolean .

so:ParamExecuteNotes a owl:Class ;
    rdfs:label "执行备注"@zh-CN ;
    rdfs:label "Execution Notes"@en ;
    rdfs:comment "员工执行时的备注（如：部分商品无法贴标）"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired false .

so:RuleBarcodeMustMatchSKU a owl:Class ;
    rdfs:label "校验：条码与SKU匹配"@zh-CN ;
    rdfs:comment "IF枪扫描的条码必须与任务关联的SKU条码一致"@zh-CN ;
    so:ruleType so:RuleTypeValidation ;
    so:ruleLogic "扫描条码必须等于关联SKU的条码"@zh-CN .

so:WritePropScanBarcode a owl:Class ;
    rdfs:label "写入：扫描条码"@zh-CN ;
    rdfs:comment "Action执行时写入scanBarcode"@zh-CN ;
    so:targetProperty so:scanBarcode ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamExecuteScanBarcode .

so:WritePropPriceLabelPrinted a owl:Class ;
    rdfs:label "写入：价签已打印"@zh-CN ;
    rdfs:comment "Action执行时写入priceLabelPrinted"@zh-CN ;
    so:targetProperty so:priceLabelPrinted ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValueParam so:ParamExecutePriceLabelPrinted .

so:WritePropExecutedBy a owl:Class ;
    rdfs:label "写入：执行人"@zh-CN ;
    rdfs:comment "Action执行时写入executedBy（当前登录员工）"@zh-CN ;
    so:targetProperty so:executedBy ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:CurrentActor .

so:WritePropTaskNotesExecute a owl:Class ;
    rdfs:label "写入：执行备注"@zh-CN ;
    rdfs:comment "Action执行时追加写入taskNotes"@zh-CN ;
    so:targetProperty so:taskNotes ;
    so:writeOperation so:WriteOperationAppend ;
    so:writeValueParam so:ParamExecuteNotes .

so:SideEffectPromptSubmitResult a owl:Class ;
    rdfs:label "副作用：提示提交结果"@zh-CN ;
    rdfs:comment "员工执行完成后，提示需要提交执行结果（从POS拉取数据）"@zh-CN ;
    so:sideEffectType so:SideEffectTypePrompt ;
    so:promptMessage "请提交执行结果，系统将从POS拉取销售数据"@zh-CN .

# ------------------------------------------------------------
# Action Type 5: SubmitResult — 提交执行结果（POS闭环）
# ------------------------------------------------------------
# 触发时机：员工完成操作后，从POS系统拉取实际销售数据
# 作用于：WorkTask对象（MODIFY修改 + 创建WorkTaskResult链接）
# 输入参数：resultNotes（结果备注）
# 自动写入WorkTaskResult：originalInventoryQty, soldQty, remainingQty,
#                         clearanceRate, discountedRevenue（从POS拉取）

so:SubmitResult a owl:Class ;
    rdfs:label "提交执行结果"@zh-CN ;
    rdfs:label "Submit Execution Result"@en ;
    rdfs:comment "员工执行完成后提交结果。系统从POS拉取实际销售数据，形成闭环"@zh-CN ;
    so:targetObjectType so:WorkTask ;
    so:actionOperation so:ActionOperationModify ;
    so:submissionCriteria so:CriteriaHasScannedBarcode ;
    so:submissionCriteria so:CriteriaPriceLabelPrinted ;
    so:hasParameter so:ParamSubmitNotes ;
    so:writesProperty so:WritePropResultStatusSubmitted ;
    so:writesProperty so:WritePropSubmissionTime ;
    so:writesProperty so:WritePropSubmittedBy ;
    so:writesLink so:WriteLinkHasResult ;
    so:hasSideEffect so:SideEffectNotifyManagerOnSubmit .

so:CriteriaHasScannedBarcode a owl:Class ;
    rdfs:label "条件：已完成条码扫描"@zh-CN ;
    rdfs:comment "只有scanBarcode不为空的任务才能提交结果"@zh-CN ;
    so:criteriaProperty so:scanBarcode ;
    so:criteriaOperator so:OperatorNotNull .

so:CriteriaPriceLabelPrinted a owl:Class ;
    rdfs:label "条件：已打印价签"@zh-CN ;
    rdfs:comment "只有priceLabelPrinted=true的任务才能提交结果"@zh-CN ;
    so:criteriaProperty so:priceLabelPrinted ;
    so:criteriaOperator so:OperatorEquals ;
    so:criteriaValue "true"^^xsd:boolean .

so:ParamSubmitNotes a owl:Class ;
    rdfs:label "结果备注"@zh-CN ;
    rdfs:label "Result Notes"@en ;
    rdfs:comment "员工提交结果时的备注说明"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired false .

so:WritePropResultStatusSubmitted a owl:Class ;
    rdfs:label "写入：结果状态为已提交"@zh-CN ;
    rdfs:comment "写入resultStatus=ResultSubmitted"@zh-CN ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:ResultSubmitted .

so:WritePropSubmissionTime a owl:Class ;
    rdfs:label "写入：提交时间"@zh-CN ;
    rdfs:comment "写入提交时间为当前时间戳"@zh-CN ;
    so:targetProperty so:submissionTime ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:CurrentTimestamp .

so:WritePropSubmittedBy a owl:Class ;
    rdfs:label "写入：提交人"@zh-CN ;
    rdfs:comment "写入submittedBy=当前登录员工"@zh-CN ;
    so:targetProperty so:submittedBy ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:CurrentActor .

so:WriteLinkHasResult a owl:Class ;
    rdfs:label "写入链接：创建执行结果"@zh-CN ;
    rdfs:comment "创建新的WorkTaskResult对象实例并建立hasResult链接"@zh-CN ;
    so:targetObjectType so:WorkTaskResult ;
    so:writeOperation so:WriteOperationCreate ;
    so:writeLinkProperty so:hasResult ;
    so:autoPopulateProperties so:AutoPopulatePOSData .

so:AutoPopulatePOSData a owl:Class ;
    rdfs:label "POS数据自动填充"@zh-CN ;
    rdfs:comment "WorkTaskResult创建时自动从POS系统拉取：原库存、销售数量、剩余库存、出清率、销售额"@zh-CN ;
    so:populatesProperty so:originalInventoryQty ;
    so:populatesProperty so:soldQty ;
    so:populatesProperty so:remainingQty ;
    so:populatesProperty so:clearanceRate ;
    so:populatesProperty so:discountedRevenue ;
    so:populatesProperty so:posTransactionId ;
    so:populatesProperty so:posFetchedAt ;
    so:dataSource so:POSSystem ;
    so:dataMapping "originalInventoryQty=init_stock_qty, soldQty=sold_qty, remainingQty=remaining_qty, clearanceRate=sold_qty/init_stock_qty, discountedRevenue=revenue, posTransactionId=txn_id"@zh-CN .

so:SideEffectNotifyManagerOnSubmit a owl:Class ;
    rdfs:label "副作用：通知店长复核"@zh-CN ;
    rdfs:comment "员工提交结果后，自动通知店长进行复核"@zh-CN ;
    so:sideEffectType so:SideEffectTypeNotification ;
    so:notifyRole so:RoleStoreManager ;
    so:notificationTemplate "打折任务执行结果已提交：商品【{skuName}】，出清率{clearanceRate}，请复核"@zh-CN .

# ------------------------------------------------------------
# Action Type 6: ReviewResult — 店长复核
# ------------------------------------------------------------
# 触发时机：店长看到POS数据后，复核执行结果是否达标
# 作用于：WorkTask对象（MODIFY修改）
# 输入参数：reviewStatus（复核结论）, reviewComment（复核意见）
# 自动写入WorkTaskReview：reviewStatus, reviewComment, reviewTime, reviewedBy
# 最终更新WorkTask：taskStatus, overallResult

so:ReviewResult a owl:Class ;
    rdfs:label "店长复核执行结果"@zh-CN ;
    rdfs:label "Review Execution Result"@en ;
    rdfs:comment "店长复核员工提交的执行结果，决定通过或驳回"@zh-CN ;
    so:targetObjectType so:WorkTask ;
    so:actionOperation so:ActionOperationModify ;
    so:submissionCriteria so:CriteriaResultStatusIsSubmitted ;
    so:hasParameter so:ParamReviewStatus ;
    so:hasParameter so:ParamReviewComment ;
    so:hasParameter so:ParamReviewRectificationRequired ;
    so:writesLink so:WriteLinkHasReview ;
    so:writesProperty so:WritePropOverallResult ;
    so:writesProperty so:WritePropTaskStatusCompleted ;
    so:hasSideEffect so:SideEffectNotifyEmployeeOnReview .

so:CriteriaResultStatusIsSubmitted a owl:Class ;
    rdfs:label "条件：结果状态为已提交"@zh-CN ;
    rdfs:comment "只有resultStatus=ResultSubmitted的任务才能复核"@zh-CN ;
    so:criteriaProperty so:hasResult ;
    so:criteriaOperator so:OperatorLinkExists ;
    so:criteriaTargetProperty so:resultStatus ;
    so:criteriaValue so:ResultSubmitted .

so:ParamReviewStatus a owl:Class ;
    rdfs:label "复核结论"@zh-CN ;
    rdfs:label "Review Status"@en ;
    rdfs:comment "店长复核结论：通过/驳回/需整改"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramObjectType so:ReviewStatus ;
    so:paramRequired true ;
    so:paramOptions so:ReviewPassed, so:RectificationRequired, so:ReviewRejected .

so:ParamReviewComment a owl:Class ;
    rdfs:label "复核意见"@zh-CN ;
    rdfs:label "Review Comment"@en ;
    rdfs:comment "店长复核的具体意见"@zh-CN ;
    so:paramSource so:ParameterSourceUserInput ;
    so:paramDataType xsd:string ;
    so:paramRequired false .

so:ParamReviewRectificationRequired a owl:Class ;
    rdfs:label "需整改"@zh-CN ;
    rdfs:label "Rectification Required"@en ;
    rdfs:comment "复核驳回时是否要求员工整改"@zh-CN ;
    so:paramSource so:ParameterSourceDerived ;
    so:paramDataType xsd:boolean ;
    so:paramRequired false ;
    so:paramDefaultValue "false"^^xsd:boolean ;
    so:derivedFrom so:ParamReviewStatus ;
    so:derivationLogic "当reviewStatus=ReviewRejected时为true"@zh-CN .

so:WriteLinkHasReview a owl:Class ;
    rdfs:label "写入链接：创建复核记录"@zh-CN ;
    rdfs:comment "创建新的WorkTaskReview对象实例并建立hasReview链接"@zh-CN ;
    so:targetObjectType so:WorkTaskReview ;
    so:writeOperation so:WriteOperationCreate ;
    so:writeLinkProperty so:hasReview ;
    so:autoPopulateProperties so:AutoPopulateReviewData .

so:AutoPopulateReviewData a owl:Class ;
    rdfs:label "复核数据自动填充"@zh-CN ;
    rdfs:comment "WorkTaskReview创建时自动填充：reviewId, reviewTime, reviewedBy, reviewStatus, reviewComment"@zh-CN ;
    so:populatesProperty so:reviewId ;
    so:populatesProperty so:reviewTime ;
    so:populatesProperty so:reviewedBy ;
    so:populatesProperty so:reviewStatus ;
    so:populatesProperty so:reviewComment ;
    so:populatesProperty so:rectificationRequired ;
    so:autoIDPrefix "REV-" ;
    so:autoIDTimestamp true .

so:WritePropOverallResult a owl:Class ;
    rdfs:label "写入：综合结论"@zh-CN ;
    rdfs:comment "根据复核结论写入overallResult：ReviewPassed→DiscountSuccess，ReviewRejected→DiscountFail"@zh-CN ;
    so:targetProperty so:overallResult ;
    so:writeOperation so:WriteOperationConditional ;
    so:conditionWrite so:ConditionReviewPassed ;
    so:conditionWrite so:ConditionReviewRejected .

so:ConditionReviewPassed a owl:Class ;
    rdfs:label "条件：通过时"@zh-CN ;
    rdfs:comment "复核通过时写入DiscountSuccess"@zh-CN ;
    so:conditionParam so:ParamReviewStatus ;
    so:conditionValue so:ReviewPassed ;
    so:writeValue so:DiscountSuccess .

so:ConditionReviewRejected a owl:Class ;
    rdfs:label "条件：驳回时"@zh-CN ;
    rdfs:comment "复核驳回时写入DiscountFail"@zh-CN ;
    so:conditionParam so:ParamReviewStatus ;
    so:conditionValue so:ReviewRejected ;
    so:writeValue so:DiscountFail .

so:WritePropTaskStatusCompleted a owl:Class ;
    rdfs:label "写入：任务状态为已完成"@zh-CN ;
    rdfs:comment "复核完成后写入taskStatus=TaskCompleted"@zh-CN ;
    so:targetProperty so:taskStatus ;
    so:writeOperation so:WriteOperationSet ;
    so:writeValue so:TaskCompleted .

so:SideEffectNotifyEmployeeOnReview a owl:Class ;
    rdfs:label "副作用：通知员工复核结果"@zh-CN ;
    rdfs:comment "店长复核后通知执行员工结果"@zh-CN ;
    so:sideEffectType so:SideEffectTypeNotification ;
    so:notifyRole so:RoleFrontline ;
    so:notificationTemplate "打折任务【{taskId}】复核结果：{reviewStatus}，意见：{reviewComment}"@zh-CN .

