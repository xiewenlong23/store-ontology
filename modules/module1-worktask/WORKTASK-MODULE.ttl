# ============================================================
# 补充部分：品类出清促销规则本体
# ============================================================
# 本体建模：超市行业商品出清促销规则
# 
# 核心概念：
#   Category          - 品类分类（9大类，含层级结构）
#   DiscountTier      - 折扣层级（按保质期剩余天数定义折扣区间）
#   ClearanceRule     - 出清规则（品类+折扣层级+约束）
#   ExemptionRule     - 豁免规则（哪些商品不能打折）
#
# 知识库用途：
#   AI 推理：给定 SKU + 保质期 + 库存 → 推荐折扣
#   SPARQL 查询：按品类查规则、按紧迫度排序
# ============================================================

# ------------------------------------------------------------
# 第七部分：品类分类（Category）
# ------------------------------------------------------------
# 品类紧迫度：高=立即出清，中=尽快出清，低=常规出清

so:FreshProduce a owl:Class ;
    rdfs:label "生鲜"@zh-CN ;
    rdfs:label "Fresh Produce"@en ;
    rdfs:comment "生鲜品类：包括蔬菜、水果等，保质期短，出清紧迫度最高"@zh-CN ;
    so:categoryType so:CategoryTypeFresh ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 3 .

so:MeatPoultry a owl:Class ;
    rdfs:label "肉禽"@zh-CN ;
    rdfs:label "Meat & Poultry"@en ;
    rdfs:comment "肉禽品类：鲜肉、冷鲜肉、冷冻肉，保质期短"@zh-CN ;
    so:categoryType so:CategoryTypeFresh ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 5 .

so:Seafood a owl:Class ;
    rdfs:label "水产"@zh-CN ;
    rdfs:label "Seafood"@en ;
    rdfs:comment "水产品类：活鲜、冰鲜、冷冻海鲜"@zh-CN ;
    so:categoryType so:CategoryTypeFresh ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 3 .

so:Dairy a owl:Class ;
    rdfs:label "乳品"@zh-CN ;
    rdfs:label "Dairy"@en ;
    rdfs:comment "乳品品类：牛奶、酸奶、乳饮料，保质期较短"@zh-CN ;
    so:categoryType so:CategoryTypeChilled ;
    so:clearanceUrgency so:UrgencyMedium ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 7 .

so:Bakery a owl:Class ;
    rdfs:label "烘焙"@zh-CN ;
    rdfs:label "Bakery"@en ;
    rdfs:comment "烘焙品类：面包、蛋糕、西点，保质期极短"@zh-CN ;
    so:categoryType so:CategoryTypeFresh ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 2 .

so:FrozenFood a owl:Class ;
    rdfs:label "冷冻食品"@zh-CN ;
    rdfs:label "Frozen Food"@en ;
    rdfs:comment "冷冻品类：速冻米面、冰淇淋等，需冷冻保存"@zh-CN ;
    so:categoryType so:CategoryTypeFrozen ;
    so:clearanceUrgency so:UrgencyLow ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 30 .

so:Beverage a owl:Class ;
    rdfs:label "饮品"@zh-CN ;
    rdfs:label "Beverage"@en ;
    rdfs:comment "饮品类：饮料、瓶装水、果汁等"@zh-CN ;
    so:categoryType so:CategoryTypeAmbient ;
    so:clearanceUrgency so:UrgencyLow ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 60 .

so:SnackFood a owl:Class ;
    rdfs:label "休闲食品"@zh-CN ;
    rdfs:label "Snack Food"@en ;
    rdfs:comment "休闲食品品类：饼干、糖果、坚果等"@zh-CN ;
    so:categoryType so:CategoryTypeAmbient ;
    so:clearanceUrgency so:UrgencyLow ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 90 .

so:RiceGrainOil a owl:Class ;
    rdfs:label "米面粮油"@zh-CN ;
    rdfs:label "Rice, Grain & Cooking Oil"@en ;
    rdfs:comment "米面粮油品类：大米、面粉、食用油等，保质期较长"@zh-CN ;
    so:categoryType so:CategoryTypeAmbient ;
    so:clearanceUrgency so:UrgencyLow ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 180 .

so:DailyFresh a owl:Class ;
    rdfs:label "日配"@zh-CN ;
    rdfs:label "Daily Fresh"@en ;
    rdfs:comment "日配品类：豆腐、豆制品、卤味等，需当日消耗"@zh-CN ;
    so:categoryType so:CategoryTypeFresh ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:parentCategory so:CategoryRoot ;
    so:standardShelfLifeDays 1 .

so:CategoryRoot a owl:Class ;
    rdfs:label "根品类"@zh-CN ;
    rdfs:label "Root Category"@en ;
    rdfs:comment "品类分类根节点"@zh-CN .

# ------------------------------------------------------------
# 第八部分：折扣层级（DiscountTier）
# ------------------------------------------------------------
# 折扣层级定义：按保质期剩余天数划分折扣区间
# 折扣率：0.0=免费送，1.0=原价，0.3=3折

# 层级1：保质期剩余1天（最紧急）
so:TierShelfLife1Day a owl:Class ;
    rdfs:label "T1-临期1天"@zh-CN ;
    rdfs:label "Tier 1: 1 Day Remaining"@en ;
    rdfs:comment "保质期剩余1天，强制出清"@zh-CN ;
    so:tierMinDays 0 ;
    so:tierMaxDays 1 ;
    so:minDiscountRate 0.1 ;
    so:maxDiscountRate 0.5 ;
    so:recommendedDiscountRate 0.2 ;
    so:tierOrder 1 ;
    so:tierUrgency so:UrgencyCritical .

# 层级2：保质期剩余2-3天
so:TierShelfLife2to3Days a owl:Class ;
    rdfs:label "T2-临期2-3天"@zh-CN ;
    rdfs:label "Tier 2: 2-3 Days Remaining"@en ;
    rdfs:comment "保质期剩余2-3天，积极出清"@zh-CN ;
    so:tierMinDays 2 ;
    so:tierMaxDays 3 ;
    so:minDiscountRate 0.3 ;
    so:maxDiscountRate 0.6 ;
    so:recommendedDiscountRate 0.4 ;
    so:tierOrder 2 ;
    so:tierUrgency so:UrgencyHigh .

# 层级3：保质期剩余4-7天
so:TierShelfLife4to7Days a owl:Class ;
    rdfs:label "T3-临期4-7天"@zh-CN ;
    rdfs:label "Tier 3: 4-7 Days Remaining"@en ;
    rdfs:comment "保质期剩余4-7天，常规出清"@zh-CN ;
    so:tierMinDays 4 ;
    so:tierMaxDays 7 ;
    so:minDiscountRate 0.5 ;
    so:maxDiscountRate 0.8 ;
    so:recommendedDiscountRate 0.7 ;
    so:tierOrder 3 ;
    so:tierUrgency so:UrgencyMedium .

# 层级4：保质期剩余8-14天
so:TierShelfLife8to14Days a owl:Class ;
    rdfs:label "T4-临期8-14天"@zh-CN ;
    rdfs:label "Tier 4: 8-14 Days Remaining"@en ;
    rdfs:comment "保质期剩余8-14天，预防性出清"@zh-CN ;
    so:tierMinDays 8 ;
    so:tierMaxDays 14 ;
    so:minDiscountRate 0.7 ;
    so:maxDiscountRate 0.9 ;
    so:recommendedDiscountRate 0.85 ;
    so:tierOrder 4 ;
    so:tierUrgency so:UrgencyLow .

# 层级5：保质期剩余15-30天
so:TierShelfLife15to30Days a owl:Class ;
    rdfs:label "T5-临期15-30天"@zh-CN ;
    rdfs:label "Tier 5: 15-30 Days Remaining"@en ;
    rdfs:comment "保质期剩余15-30天，预警提醒"@zh-CN ;
    so:tierMinDays 15 ;
    so:tierMaxDays 30 ;
    so:minDiscountRate 0.9 ;
    so:maxDiscountRate 1.0 ;
    so:recommendedDiscountRate 0.95 ;
    so:tierOrder 5 ;
    so:tierUrgency so:UrgencyPreventive .

# ------------------------------------------------------------
# 第九部分：出清规则（ClearanceRule）
# ------------------------------------------------------------
# 每个品类 × 紧迫度 = 一条出清规则
# 规则定义了适用的折扣层级序列

# --- ClearanceRule ObjectProperty 声明 ---
so:appliesToCategory a owl:ObjectProperty ;
    rdfs:domain so:ClearanceRule ;
    rdfs:range so:Category ;
    rdfs:label "适用于品类"@zh-CN ;
    rdfs:label "Applies to Category"@en .

so:hasDiscountTier a owl:ObjectProperty ;
    rdfs:domain so:ClearanceRule ;
    rdfs:range so:DiscountTier ;
    rdfs:label "折扣层级"@zh-CN ;
    rdfs:label "Has Discount Tier"@en .

so:minimumExpiryDaysForClearance a owl:DatatypeProperty ;
    rdfs:domain so:ClearanceRule ;
    rdfs:range xsd:integer ;
    rdfs:label "最低临期天数"@zh-CN ;
    rdfs:label "Minimum Expiry Days for Clearance"@en ;
    rdfs:comment "触发出清的最低临期天数阈值，低于此天数则激活出清规则"@zh-CN .

# --- ClearanceRule Class ---
so:ClearanceRule a owl:Class ;
    rdfs:label "出清规则"@zh-CN ;
    rdfs:label "Clearance Rule"@en ;
    rdfs:comment "定义某品类的临期出清折扣规则，包含适用的折扣层级序列"@zh-CN .

# --- DiscountTier Class (层级基类) ---
so:DiscountTier a owl:Class ;
    rdfs:label "折扣层级"@zh-CN ;
    rdfs:label "Discount Tier"@en ;
    rdfs:comment "按保质期剩余天数划分的折扣层级"@zh-CN .

# --- (UrgencyLevel moved to 第十一部分) ---

# 生鲜出清规则（高紧迫度：1天→1折，2-3天→3折，4-7天→6折）
so:RuleFreshProduceClearance a owl:Class ;
    rdfs:label "生鲜出清规则"@zh-CN ;
    rdfs:comment "生鲜品类出清规则：保质期短，出清紧迫度最高"@zh-CN ;
    so:appliesToCategory so:FreshProduce ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 肉禽出清规则
so:RuleMeatPoultryClearance a owl:Class ;
    rdfs:label "肉禽出清规则"@zh-CN ;
    rdfs:comment "肉禽品类出清规则：保质期短，需冷链管理"@zh-CN ;
    so:appliesToCategory so:MeatPoultry ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 水产出清规则
so:RuleSeafoodClearance a owl:Class ;
    rdfs:label "水产出清规则"@zh-CN ;
    rdfs:comment "水产品类出清规则：活鲜保质期极短，冰鲜次之"@zh-CN ;
    so:appliesToCategory so:Seafood ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 乳品出清规则（中紧迫度）
so:RuleDairyClearance a owl:Class ;
    rdfs:label "乳品出清规则"@zh-CN ;
    rdfs:comment "乳品品类出清规则：保质期较短，出清紧迫度中等"@zh-CN ;
    so:appliesToCategory so:Dairy ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:hasDiscountTier so:TierShelfLife15to30Days ;
    so:clearanceUrgency so:UrgencyMedium ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 烘焙出清规则（最高紧迫度）
so:RuleBakeryClearance a owl:Class ;
    rdfs:label "烘焙出清规则"@zh-CN ;
    rdfs:comment "烘焙品类出清规则：保质期极短（通常1-2天），需当日出清"@zh-CN ;
    so:appliesToCategory so:Bakery ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:clearanceUrgency so:UrgencyHigh ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 冷冻食品出清规则（低紧迫度）
so:RuleFrozenFoodClearance a owl:Class ;
    rdfs:label "冷冻食品出清规则"@zh-CN ;
    rdfs:comment "冷冻食品品类出清规则：保质期较长，出清紧迫度低"@zh-CN ;
    so:appliesToCategory so:FrozenFood ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:hasDiscountTier so:TierShelfLife15to30Days ;
    so:clearanceUrgency so:UrgencyLow ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 饮品出清规则（低紧迫度）
so:RuleBeverageClearance a owl:Class ;
    rdfs:label "饮品出清规则"@zh-CN ;
    rdfs:comment "饮品类出清规则：保质期较长，出清紧迫度低"@zh-CN ;
    so:appliesToCategory so:Beverage ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:hasDiscountTier so:TierShelfLife15to30Days ;
    so:clearanceUrgency so:UrgencyLow ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 休闲食品出清规则（低紧迫度）
so:RuleSnackFoodClearance a owl:Class ;
    rdfs:label "休闲食品出清规则"@zh-CN ;
    rdfs:comment "休闲食品品类出清规则：保质期较长，出清紧迫度低"@zh-CN ;
    so:appliesToCategory so:SnackFood ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:hasDiscountTier so:TierShelfLife15to30Days ;
    so:clearanceUrgency so:UrgencyLow ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 米面粮油出清规则（最低紧迫度）
so:RuleRiceGrainOilClearance a owl:Class ;
    rdfs:label "米面粮油出清规则"@zh-CN ;
    rdfs:comment "米面粮油品类出清规则：保质期长，出清紧迫度最低"@zh-CN ;
    so:appliesToCategory so:RiceGrainOil ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:hasDiscountTier so:TierShelfLife4to7Days ;
    so:hasDiscountTier so:TierShelfLife8to14Days ;
    so:hasDiscountTier so:TierShelfLife15to30Days ;
    so:clearanceUrgency so:UrgencyLow ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# 日配出清规则（最高紧迫度，当日必须出清）
so:RuleDailyFreshClearance a owl:Class ;
    rdfs:label "日配出清规则"@zh-CN ;
    rdfs:comment "日配品类出清规则：保质期仅1天，当日必须出清"@zh-CN ;
    so:appliesToCategory so:DailyFresh ;
    so:hasDiscountTier so:TierShelfLife1Day ;
    so:hasDiscountTier so:TierShelfLife2to3Days ;
    so:clearanceUrgency so:UrgencyCritical ;
    so:ruleStatus so:RuleStatusActive ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleEffectiveDate "2024-01-01"^^xsd:date ;
    so:storeScope so:StoreScopeAll .

# ------------------------------------------------------------
# 第十部分：豁免规则（ExemptionRule）
# ------------------------------------------------------------

# --- ExemptionRule ObjectProperty 声明 ---
so:exemptionType a owl:ObjectProperty ;
    rdfs:domain so:ExemptionRule ;
    rdfs:range so:ExemptionType ;
    rdfs:label "豁免类型"@zh-CN ;
    rdfs:label "Exemption Type"@en .

so:exemptionReason a owl:DatatypeProperty ;
    rdfs:domain so:ExemptionRule ;
    rdfs:range xsd:string ;
    rdfs:label "豁免原因"@zh-CN ;
    rdfs:label "Exemption Reason"@en .

so:ruleSource a owl:ObjectProperty ;
    rdfs:domain so:ExemptionRule ;
    rdfs:range so:RuleSource ;
    rdfs:label "规则来源"@zh-CN ;
    rdfs:label "Rule Source"@en .

so:ruleStatus a owl:ObjectProperty ;
    rdfs:domain so:ExemptionRule ;
    rdfs:range so:RuleStatus ;
    rdfs:label "规则状态"@zh-CN ;
    rdfs:label "Rule Status"@en .

# 豁免规则：定义哪些情况下商品不参与打折

# 进口商品不参与临期打折（品质要求高）
so:ExemptionImportedGoods a owl:Class ;
    rdfs:label "进口商品豁免"@zh-CN ;
    rdfs:comment "进口商品因追溯要求和品质标准，不参与临期打折"@zh-CN ;
    so:exemptionType so:ExemptionTypeImported ;
    so:exemptionReason "进口商品须确保品质，不参与临期打折"@zh-CN ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleStatus so:RuleStatusActive ;
    so:maxDiscountRate 1.0 ;
    so:appliesToAllCategories false .

# 有机/绿色食品不参与打折（品牌保护）
so:ExemptionOrganicGoods a owl:Class ;
    rdfs:label "有机绿色食品豁免"@zh-CN ;
    rdfs:comment "有机食品、绿色食品因品牌保护，不参与临期打折"@zh-CN ;
    so:exemptionType so:ExemptionTypeOrganic ;
    so:exemptionReason "有机/绿色食品品牌价值高，不参与临期打折"@zh-CN ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleStatus so:RuleStatusActive ;
    so:maxDiscountRate 1.0 ;
    so:appliesToAllCategories false .

# 促销商品有价格保护（已有折扣，不再叠加）
so:ExemptionAlreadyPromoted a owl:Class ;
    rdfs:label "促销中商品豁免"@zh-CN ;
    rdfs:comment "正在参与总部促销活动的商品，不叠加临期折扣"@zh-CN ;
    so:exemptionType so:ExemptionTypeAlreadyPromoted ;
    so:exemptionReason "已参与促销的商品不叠加折扣，保护价格体系"@zh-CN ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleStatus so:RuleStatusActive ;
    so:maxDiscountRate 1.0 ;
    so:appliesToAllCategories true .

# 新上架商品不打折（定价策略）
so:ExemptionNewArrival a owl:Class ;
    rdfs:label "新上架商品豁免"@zh-CN ;
    rdfs:comment "新到货商品（到货日期7天内）不参与临期打折，维护价格形象"@zh-CN ;
    so:exemptionType so:ExemptionTypeNewArrival ;
    so:exemptionReason "新上架商品不参与临期打折"@zh-CN ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleStatus so:RuleStatusActive ;
    so:minDaysSinceArrival 0 ;
    so:maxDaysSinceArrival 7 ;
    so:maxDiscountRate 1.0 ;
    so:appliesToAllCategories true .

# 总部强制禁止打折品类
so:ExemptionHeadquartersBan a owl:Class ;
    rdfs:label "总部禁止打折"@zh-CN ;
    rdfs:comment "总部强制指定不得打折的品类或单品"@zh-CN ;
    so:exemptionType so:ExemptionTypeHeadquartersBan ;
    so:exemptionReason "总部强制禁止打折"@zh-CN ;
    so:ruleSource so:RuleSourceHeadquarters ;
    so:ruleStatus so:RuleStatusActive ;
    so:maxDiscountRate 1.0 ;
    so:appliesToAllCategories false .

# 门店级别豁免（门店可申请的特殊豁免，需总部审批）
so:ExemptionStoreLocal a owl:Class ;
    rdfs:label "门店本地豁免"@zh-CN ;
    rdfs:comment "门店因特殊原因（场地限制/客群差异）申请的本地豁免规则"@zh-CN ;
    so:exemptionType so:ExemptionTypeStoreLocal ;
    so:exemptionReason "门店本地特殊原因"@zh-CN ;
    so:ruleSource so:RuleSourceStore ;
    so:ruleStatus so:RuleStatusPendingApproval ;
    so:maxDiscountRate 1.0 ;
    so:appliesToAllCategories false ;
    so:requiresApproval true ;
    so:approvalStatus so:ApprovalStatusPending .

# ------------------------------------------------------------
# 第十一部分：枚举值（NamedIndividual）
# ------------------------------------------------------------

# 紧迫度
so:UrgencyLevel a owl:Class ;
    rdfs:label "紧迫度等级"@zh-CN ;
    rdfs:comment "商品出清的紧迫程度分级"@zh-CN .

so:UrgencyCritical a owl:NamedIndividual ;
    rdfs:label "紧急"@zh-CN ;
    rdfs:label "Critical"@en ;
    rdfs:subClassOf so:UrgencyLevel .

so:UrgencyHigh a owl:NamedIndividual ;
    rdfs:label "高"@zh-CN ;
    rdfs:label "High"@en ;
    rdfs:subClassOf so:UrgencyLevel .

so:UrgencyMedium a owl:NamedIndividual ;
    rdfs:label "中"@zh-CN ;
    rdfs:label "Medium"@en ;
    rdfs:subClassOf so:UrgencyLevel .

so:UrgencyLow a owl:NamedIndividual ;
    rdfs:label "低"@zh-CN ;
    rdfs:label "Low"@en ;
    rdfs:subClassOf so:UrgencyLevel .

so:UrgencyPreventive a owl:NamedIndividual ;
    rdfs:label "预防性"@zh-CN ;
    rdfs:label "Preventive"@en ;
    rdfs:subClassOf so:UrgencyLevel .

# 品类类型
so:CategoryType a owl:Class ;
    rdfs:label "品类类型"@zh-CN ;
    rdfs:comment "品类的温度保存类型分类"@zh-CN .

so:CategoryTypeFresh a owl:NamedIndividual ;
    rdfs:label "鲜品类"@zh-CN ;
    rdfs:subClassOf so:CategoryType .

so:CategoryTypeChilled a owl:NamedIndividual ;
    rdfs:label "冷藏品类"@zh-CN ;
    rdfs:subClassOf so:CategoryType .

so:CategoryTypeFrozen a owl:NamedIndividual ;
    rdfs:label "冷冻品类"@zh-CN ;
    rdfs:subClassOf so:CategoryType .

so:CategoryTypeAmbient a owl:NamedIndividual ;
    rdfs:label "常温品类"@zh-CN ;
    rdfs:subClassOf so:CategoryType .

# 规则状态
so:RuleStatus a owl:Class ;
    rdfs:label "规则状态"@zh-CN .

so:RuleStatusActive a owl:NamedIndividual ;
    rdfs:label "生效中"@zh-CN ;
    rdfs:subClassOf so:RuleStatus .

so:RuleStatusInactive a owl:NamedIndividual ;
    rdfs:label "已失效"@zh-CN ;
    rdfs:subClassOf so:RuleStatus .

so:RuleStatusPendingApproval a owl:NamedIndividual ;
    rdfs:label "待审批"@zh-CN ;
    rdfs:subClassOf so:RuleStatus .

# 规则来源
so:RuleSource a owl:Class ;
    rdfs:label "规则来源"@zh-CN .

so:RuleSourceHeadquarters a owl:NamedIndividual ;
    rdfs:label "总部规则"@zh-CN ;
    rdfs:label "Headquarters"@en ;
    rdfs:subClassOf so:RuleSource .

so:RuleSourceStore a owl:NamedIndividual ;
    rdfs:label "门店规则"@zh-CN ;
    rdfs:label "Store"@en ;
    rdfs:subClassOf so:RuleSource .

# 豁免类型
so:ExemptionType a owl:Class ;
    rdfs:label "豁免类型"@zh-CN .

so:ExemptionTypeImported a owl:NamedIndividual ;
    rdfs:label "进口商品"@zh-CN ;
    rdfs:subClassOf so:ExemptionType .

so:ExemptionTypeOrganic a owl:NamedIndividual ;
    rdfs:label "有机绿色"@zh-CN ;
    rdfs:subClassOf so:ExemptionType .

so:ExemptionTypeAlreadyPromoted a owl:NamedIndividual ;
    rdfs:label "促销中商品"@zh-CN ;
    rdfs:subClassOf so:ExemptionType .

so:ExemptionTypeNewArrival a owl:NamedIndividual ;
    rdfs:label "新上架商品"@zh-CN ;
    rdfs:subClassOf so:ExemptionType .

so:ExemptionTypeHeadquartersBan a owl:NamedIndividual ;
    rdfs:label "总部禁止"@zh-CN ;
    rdfs:subClassOf so:ExemptionType .

so:ExemptionTypeStoreLocal a owl:NamedIndividual ;
    rdfs:label "门店本地"@zh-CN ;
    rdfs:subClassOf so:ExemptionType .

# 审批状态
so:ApprovalStatus a owl:Class ;
    rdfs:label "审批状态"@zh-CN .

so:ApprovalStatusPending a owl:NamedIndividual ;
    rdfs:label "待审批"@zh-CN ;
    rdfs:subClassOf so:ApprovalStatus .

so:ApprovalStatusApproved a owl:NamedIndividual ;
    rdfs:label "已批准"@zh-CN ;
    rdfs:subClassOf so:ApprovalStatus .

so:ApprovalStatusRejected a owl:NamedIndividual ;
    rdfs:label "已拒绝"@zh-CN ;
    rdfs:subClassOf so:ApprovalStatus .

# 适用范围
so:StoreScope a owl:Class ;
    rdfs:label "门店适用范围"@zh-CN .

so:StoreScopeAll a owl:NamedIndividual ;
    rdfs:label "全部门店"@zh-CN ;
    rdfs:subClassOf so:StoreScope .

########## END OF CLEARANCE RULE MODULE ##########

# ============================================================
# 第二部分：Staff（员工）Object Type
# ============================================================

so:Staff a owl:Class ;
    rdfs:label "员工"@zh-CN ;
    rdfs:label "Staff"@en ;
    rdfs:comment "门店员工实体，包含店长/店员/总部人员等角色"@zh-CN .

# ── Staff DatatypeProperties ────────────────────────────────────

so:staffCode a owl:DatatypeProperty ;
    rdfs:domain so:Staff ;
    rdfs:range xsd:string ;
    rdfs:label "员工编号"@zh-CN ;
    rdfs:comment "员工工号，如 EMP-001"@zh-CN .

so:staffName a owl:DatatypeProperty ;
    rdfs:domain so:Staff ;
    rdfs:range xsd:string ;
    rdfs:label "员工姓名"@zh-CN .

so:staffPhone a owl:DatatypeProperty ;
    rdfs:domain so:Staff ;
    rdfs:range xsd:string ;
    rdfs:label "联系电话"@zh-CN .

so:hireDate a owl:DatatypeProperty ;
    rdfs:domain so:Staff ;
    rdfs:range xsd:date ;
    rdfs:label "入职日期"@zh-CN .

so:staffStatus a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:StaffStatus ;
    rdfs:label "员工状态"@zh-CN ;
    rdfs:comment "在职/离职/调转"@zh-CN .

# ── Staff ObjectProperties（关系）─────────────────────────────────

so:worksAt a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:Store ;
    rdfs:label "工作门店"@zh-CN ;
    rdfs:comment "员工所属门店"@zh-CN .

so:hasRole a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:StaffRole ;
    rdfs:label "角色"@zh-CN ;
    rdfs:comment "店长/副店长/店员/总部人员"@zh-CN .

so:manages a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:Inventory ;
    rdfs:label "管理库存"@zh-CN ;
    rdfs:comment "员工负责管理的库存记录"@zh-CN .

# 逆属性
so:managedBy a owl:ObjectProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range so:Staff ;
    owl:inverseOf so:manages ;
    rdfs:label "管理员"@zh-CN .

so:assignedTasks a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:WorkTask ;
    rdfs:label "被分配的任务"@zh-CN ;
    owl:inverseOf so:assignedTo ;
    rdfs:comment "inverse: WorkTask.assignedTo"@zh-CN .

so:executedTasks a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:WorkTask ;
    rdfs:label "已执行任务"@zh-CN ;
    owl:inverseOf so:executedBy ;
    rdfs:comment "inverse: WorkTask.executedBy"@zh-CN .

so:confirmedTasks a owl:ObjectProperty ;
    rdfs:domain so:Staff ;
    rdfs:range so:WorkTask ;
    rdfs:label "已确认任务"@zh-CN ;
    owl:inverseOf so:confirmedBy ;
    rdfs:comment "inverse: WorkTask.confirmedBy"@zh-CN .

# ── StaffRole 枚举 ──────────────────────────────────────────────

so:StaffRole a owl:Class ;
    rdfs:label "员工角色"@zh-CN .

so:RoleStoreManager a owl:NamedIndividual ;
    rdfs:label "店长"@zh-CN ;
    rdfs:subClassOf so:StaffRole .

so:RoleAssistantMgr a owl:NamedIndividual ;
    rdfs:label "副店长"@zh-CN ;
    rdfs:subClassOf so:StaffRole .

so:RoleClerk a owl:NamedIndividual ;
    rdfs:label "店员"@zh-CN ;
    rdfs:subClassOf so:StaffRole .

so:RoleHQ a owl:NamedIndividual ;
    rdfs:label "总部人员"@zh-CN ;
    rdfs:subClassOf so:StaffRole .

# ── StaffStatus 枚举 ─────────────────────────────────────────────

so:StaffStatus a owl:Class ;
    rdfs:label "员工状态"@zh-CN .

so:StaffStatusActive a owl:NamedIndividual ;
    rdfs:label "在职"@zh-CN ;
    rdfs:subClassOf so:StaffStatus .

so:StaffStatusInactive a owl:NamedIndividual ;
    rdfs:label "离职"@zh-CN ;
    rdfs:subClassOf so:StaffStatus .

so:StaffStatusTransferred a owl:NamedIndividual ;
    rdfs:label "调转"@zh-CN ;
    rdfs:subClassOf so:StaffStatus .

# ============================================================
# 第三部分：Inventory（库存）Object Type
# ============================================================

so:Inventory a owl:Class ;
    rdfs:label "库存"@zh-CN ;
    rdfs:label "Inventory"@en ;
    rdfs:comment "门店商品库存实体，独立于 Product。记录当前库存量、库位、更新时间等。"@zh-CN .

# ── Inventory DatatypeProperties ─────────────────────────────────

so:quantity a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:integer ;
    rdfs:label "当前库存数量"@zh-CN .

so:minStockLevel a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:integer ;
    rdfs:label "最低库存阈值"@zh-CN ;
    rdfs:comment "库存低于此值触发补货警告"@zh-CN .

so:maxStockLevel a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:integer ;
    rdfs:label "最高库存上限"@zh-CN .

so:reorderPoint a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:integer ;
    rdfs:label "补货点"@zh-CN ;
    rdfs:comment "库存 ≤ 此值时触发缺货警告"@zh-CN .

so:lastRestockDate a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:date ;
    rdfs:label "最近补货日期"@zh-CN .

so:lastCountDate a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:date ;
    rdfs:label "最近盘点日期"@zh-CN .

so:inventoryStatus a owl:ObjectProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range so:InventoryStatus ;
    rdfs:label "库存状态"@zh-CN .

so:inventoryLocation a owl:DatatypeProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range xsd:string ;
    rdfs:label "库位"@zh-CN ;
    rdfs:comment "如：生鲜区-A排-3层"@zh-CN .

# ── Inventory ObjectProperties（关系）───────────────────────────

so:stores a owl:ObjectProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range so:Store ;
    rdfs:label "所属门店"@zh-CN ;
    rdfs:comment "库存所属的门店"@zh-CN .

so:contains a owl:ObjectProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range so:SKU ;
    rdfs:label "存放商品"@zh-CN ;
    rdfs:comment "该库存记录对应的商品（SKU）"@zh-CN .

so:stockOf a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:Inventory ;
    owl:inverseOf so:contains ;
    rdfs:label "库存记录"@zh-CN .

so:hasEvent a owl:ObjectProperty ;
    rdfs:domain so:Inventory ;
    rdfs:range so:InventoryEvent ;
    rdfs:label "库存事件"@zh-CN ;
    rdfs:comment "该库存关联的库存事件记录"@zh-CN .

# ── InventoryStatus 枚举 ────────────────────────────────────────

so:InventoryStatus a owl:Class ;
    rdfs:label "库存状态"@zh-CN .

so:InventoryStatusNormal a owl:NamedIndividual ;
    rdfs:label "正常"@zh-CN ;
    rdfs:subClassOf so:InventoryStatus .

so:InventoryStatusNearExpiry a owl:NamedIndividual ;
    rdfs:label "临期"@zh-CN ;
    rdfs:subClassOf so:InventoryStatus .

so:InventoryStatusOutOfStock a owl:NamedIndividual ;
    rdfs:label "缺货"@zh-CN ;
    rdfs:subClassOf so:InventoryStatus .

so:InventoryStatusFrozen a owl:NamedIndividual ;
    rdfs:label "冻结"@zh-CN ;
    rdfs:subClassOf so:InventoryStatus .

# ============================================================
# 第四部分：InventoryEvent（库存事件）Object Type
# ============================================================

so:InventoryEvent a owl:Class ;
    rdfs:label "库存事件"@zh-CN ;
    rdfs:comment "库存变动触发的业务事件：临期/缺货/到货/调整/盘点"@zh-CN .

# ── InventoryEvent DatatypeProperties ───────────────────────────

so:eventTime a owl:DatatypeProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "事件时间"@zh-CN .

so:quantityBefore a owl:DatatypeProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range xsd:integer ;
    rdfs:label "变动前数量"@zh-CN .

so:quantityAfter a owl:DatatypeProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range xsd:integer ;
    rdfs:label "变动后数量"@zh-CN .

so:eventReason a owl:DatatypeProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range xsd:string ;
    rdfs:label "事件原因"@zh-CN .

# ── InventoryEvent ObjectProperties ────────────────────────────

so:eventType a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:InventoryEventType ;
    rdfs:label "事件类型"@zh-CN .

so:affects a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:Inventory ;
    rdfs:label "影响库存"@zh-CN ;
    rdfs:comment "该事件影响的库存记录"@zh-CN .

so:detectedBy a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:Staff ;
    rdfs:label "检测员工"@zh-CN ;
    rdfs:comment "发现并记录该事件的员工"@zh-CN .

so:triggers a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:WorkTask ;
    rdfs:label "触发任务"@zh-CN ;
    rdfs:comment "该事件触发的 WorkTask（临期检测→任务创建）"@zh-CN .

# 逆属性
so:triggeredByInventoryEvent a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:InventoryEvent ;
    owl:inverseOf so:triggers ;
    rdfs:label "触发来源事件"@zh-CN .

# ── InventoryEventType 枚举 ─────────────────────────────────────

so:InventoryEventType a owl:Class ;
    rdfs:label "库存事件类型"@zh-CN .

so:EventNearExpiry a owl:NamedIndividual ;
    rdfs:label "临期事件"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:EventOutOfStock a owl:NamedIndividual ;
    rdfs:label "缺货事件"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:EventRestock a owl:NamedIndividual ;
    rdfs:label "到货事件"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:EventAdjustment a owl:NamedIndividual ;
    rdfs:label "调整事件"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

so:EventCount a owl:NamedIndividual ;
    rdfs:label "盘点事件"@zh-CN ;
    rdfs:subClassOf so:InventoryEventType .

# ============================================================
# 第五部分：Product（SKU）扩展属性
# ============================================================

# ── SKU 扩展 DatatypeProperties ─────────────────────────────────

so:barcode a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "商品条码"@zh-CN ;
    rdfs:comment "EAN/UPC 条码"@zh-CN .

so:unit a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "计量单位"@zh-CN ;
    rdfs:comment "如：袋/盒/千克/升"@zh-CN .

so:costPrice a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:decimal ;
    rdfs:label "成本价"@zh-CN .

so:retailPrice a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:decimal ;
    rdfs:label "零售价"@zh-CN .

so:origin a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "产地"@zh-CN .

so:supplier a owl:DatatypeProperty ;
    rdfs:domain so:SKU ;
    rdfs:range xsd:string ;
    rdfs:label "供应商"@zh-CN .

# ── SKU 扩展 ObjectProperties ─────────────────────────────────

so:hasStock a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:Inventory ;
    rdfs:label "关联库存"@zh-CN ;
    rdfs:comment "商品对应的库存记录（多门店多库存）"@zh-CN ;
    owl:inverseOf so:stockOf .

so:hasExpiryPolicy a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:ExpiryPolicy ;
    rdfs:label "保质期政策"@zh-CN .

so:belongsToCategory a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:Category ;
    rdfs:label "所属品类"@zh-CN .

# ── ExpiryPolicy ──────────────────────────────────────────────

so:ExpiryPolicy a owl:Class ;
    rdfs:label "保质期政策"@zh-CN ;
    rdfs:comment "定义商品的标准保质期和各级预警阈值"@zh-CN .

so:standardShelfLife a owl:DatatypeProperty ;
    rdfs:domain so:ExpiryPolicy ;
    rdfs:range xsd:integer ;
    rdfs:label "标准保质期天数"@zh-CN .

so:warningThreshold a owl:DatatypeProperty ;
    rdfs:domain so:ExpiryPolicy ;
    rdfs:range xsd:integer ;
    rdfs:label "临期预警天数"@zh-CN ;
    rdfs:comment "到期前 N 天触发临期预警（默认3天）"@zh-CN .

so:clearanceThreshold a owl:DatatypeProperty ;
    rdfs:domain so:ExpiryPolicy ;
    rdfs:range xsd:integer ;
    rdfs:label "出清触发天数"@zh-CN ;
    rdfs:comment "到期前 N 天触发出清任务（默认7天）"@zh-CN .

# ============================================================
# 第六部分：WorkTask 扩展关系（关联 Product/Inventory/Staff）
# ============================================================

# ── WorkTask → Product ────────────────────────────────────────

so:relatedProduct a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:SKU ;
    rdfs:label "关联商品"@zh-CN ;
    rdfs:comment "任务关联的商品（SKU）"@zh-CN ;
    owl:inverseOf so:relatedTask ;
    rdfs:seeAlso so:relatedSKU .

so:relatedTask a owl:ObjectProperty ;
    rdfs:domain so:SKU ;
    rdfs:range so:WorkTask ;
    rdfs:label "关联任务"@zh-CN ;
    owl:inverseOf so:relatedProduct .

# ── WorkTask → Inventory ──────────────────────────────────────

so:relatedInventory a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Inventory ;
    rdfs:label "关联库存"@zh-CN ;
    rdfs:comment "任务关联的库存记录（用于库存操作类任务）"@zh-CN .

# ── WorkTask → Staff ──────────────────────────────────────────

so:assignedTo a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Staff ;
    rdfs:label "分配给"@zh-CN ;
    rdfs:comment "任务被分配给的员工"@zh-CN .

so:handledBy a owl:ObjectProperty ;
    rdfs:domain so:WorkTask ;
    rdfs:range so:Staff ;
    rdfs:label "最终执行人"@zh-CN ;
    rdfs:comment "实际执行并完成任务的人（区别于 assignedTo 分配人）"@zh-CN .

# ============================================================
# 第七部分：Store 扩展（hasStaff / hasInventory）
# ============================================================

so:hasStaff a owl:ObjectProperty ;
    rdfs:domain so:Store ;
    rdfs:range so:Staff ;
    rdfs:label "门店员工"@zh-CN ;
    owl:inverseOf so:worksAt .

so:hasInventory a owl:ObjectProperty ;
    rdfs:domain so:Store ;
    rdfs:range so:Inventory ;
    rdfs:label "门店库存"@zh-CN ;
    owl:inverseOf so:stores .

# ============================================================
# 四角实体关系总结（临期出清场景）
# ============================================================
# Product(SKU) ──hasStock──▶ Inventory ──stores──▶ Store
#                                          │
#                                     managedBy
#                                          │
#                                          ▼
#                                        Staff
#                                          │
#                                    assignedTasks
#                                          │
#                                          ▼
# InventoryEvent ◀──affects── Inventory ◀──contains── Product(SKU)
#        │                                              ▲
#     triggers                                     relatedProduct
#        │                                              │
#        ▼                                              ▼
#      WorkTask ◀──assignedTo── Staff ◀──worksAt── Store
#
# 临期出清完整链路：
#   Product expiry_date 临近 → Inventory.status = NearExpiry
#   → InventoryEvent(triggers) → WorkTask(relatedProduct/relatedInventory)
#   → WorkTask.assignedTo → Staff
#   → Staff.executedTasks → WorkTask 闭环
########## END OF FOUR-CORNER ENTITY MODULE ##########
