so:ActionOperation a owl:Class ;
    rdfs:label "Action操作类型"@zh-CN ;
    rdfs:comment "Action Type的操作类型枚举"@zh-CN .

so:ActionOperationCreate a owl:NamedIndividual ;
    rdfs:label "新建"@zh-CN ;
    rdfs:label "Create"@en ;
    rdfs:subClassOf so:ActionOperation .

so:ActionOperationModify a owl:NamedIndividual ;
    rdfs:label "修改"@zh-CN ;
    rdfs:label "Modify"@en ;
    rdfs:subClassOf so:ActionOperation .

so:ActionOperationDelete a owl:NamedIndividual ;
    rdfs:label "删除"@zh-CN ;
    rdfs:label "Delete"@en ;
    rdfs:subClassOf so:ActionOperation .

