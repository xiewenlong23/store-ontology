so:hasEmployee a owl:ObjectProperty ;
    rdfs:domain so:Store ;
    rdfs:range so:Employee ;
    rdfs:label "门店员工"@zh-CN ;
    rdfs:label "Has Employee"@en .

# --- EmployeeRole 枚举 ---
so:EmployeeRole a owl:Class ;
    rdfs:label "员工角色"@zh-CN ;
    rdfs:comment "员工角色枚举"@zh-CN .

so:RoleStoreManager a owl:NamedIndividual ;
    rdfs:label "店长"@zh-CN ;
    rdfs:subClassOf so:EmployeeRole .

so:RoleAssistantManager a owl:NamedIndividual ;
    rdfs:label "副店长"@zh-CN ;
    rdfs:subClassOf so:EmployeeRole .

so:RoleStaff a owl:NamedIndividual ;
    rdfs:label "员工"@zh-CN ;
    rdfs:subClassOf so:EmployeeRole .

# --- InventoryEvent（库存事件）---
so:InventoryEvent a owl:Class ;
    rdfs:label "库存事件"@zh-CN ;
    rdfs:label "Inventory Event"@en ;
    rdfs:comment "库存事件：记录某商品在特定时间点的库存快照，用于临期检测和出清触发"@zh-CN .

so:eventType a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:InventoryEventType ;
    rdfs:label "事件类型"@zh-CN ;
    rdfs:label "Event Type"@en .

so:eventTime a owl:DatatypeProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "事件时间"@zh-CN ;
    rdfs:label "Event Time"@en .

so:quantityAtEvent a owl:DatatypeProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range xsd:integer ;
    rdfs:label "事件时库存"@zh-CN ;
    rdfs:label "Quantity at Event"@en .

so:relatedSKU a owl:ObjectProperty ;
    rdfs:domain so:InventoryEvent ;
    rdfs:range so:SKU ;
    rdfs:label "关联商品"@zh-CN ;
    rdfs:label "Related SKU"@en ;
