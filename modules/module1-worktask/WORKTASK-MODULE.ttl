    rdfs:label "Promotion"@en ;
    rdfs:comment "促销活动实体，支持临期打折促销活动"@zh-CN .

so:promotionType a owl:ObjectProperty ;
    rdfs:domain so:Promotion ;
    rdfs:range so:PromotionType ;
    rdfs:label "促销类型"@zh-CN ;
    rdfs:label "Promotion Type"@en .

so:discountRate a owl:DatatypeProperty ;
    rdfs:domain so:Promotion ;
    rdfs:range xsd:decimal ;
    rdfs:label "折扣率"@zh-CN ;
    rdfs:label "Discount Rate"@en .

# --- PromotionType 枚举 ---
so:PromotionType a owl:Class ;
    rdfs:label "促销类型"@zh-CN .

so:PromotionTypeClearance a owl:NamedIndividual ;
    rdfs:label "临期出清"@zh-CN ;
