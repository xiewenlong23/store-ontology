@prefix store: <http://example.org/store-ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# Object Types (对象类型)
# ============================================================

store:Region a rdfs:Class ;
    rdfs:label "区域"@zh , "Region"@en ;
    rdfs:comment "地理区域，用于组织门店"@zh ;
    store:properties "id:string,name:string,code:string" ;
    store:storage "regions.json" .

store:Store a rdfs:Class ;
    rdfs:label "门店"@zh , "Store"@en ;
    rdfs:comment "零售门店"@zh ;
    store:properties "id:string,name:string,region_id:string,address:string,manager_id:string,created_at:datetime" ;
    store:storage "stores.json" .

store:Employee a rdfs:Class ;
    rdfs:label "员工"@zh , "Employee"@en ;
    rdfs:comment "门店员工"@zh ;
    store:properties "id:string,name:string,store_id:string,role:EmployeeRole,phone:string" ;
    store:storage "employees.json" .

store:Product a rdfs:Class ;
    rdfs:label "商品"@zh , "Product"@en ;
    rdfs:comment "销售商品"@zh ;
    store:properties "id:string,name:string,category:string,brand:string,unit:string,cost_price:float,retail_price:float" ;
    store:storage "products.json" .

store:NearExpiryProduct a rdfs:Class ;
    rdfs:label "临期商品"@zh , "Near Expiry Product"@en ;
    rdfs:comment "即将过期的商品实例"@zh ;
    store:properties "id:string,product_id:string,store_id:string,batch_no:string,production_date:date,expiry_date:date,stock_quantity:int,days_left:int,discount_tier:DiscountTier,status:ProductStatus" ;
    store:storage "near_expiry_products.json" .

# Task — 通用任务 Object Type
# Action Type 的执行记录实例
store:Task a rdfs:Class ;
    rdfs:label "任务"@zh , "Task"@en ;
    rdfs:comment "Action Type 执行记录，type 字段标识操作类型"@zh ;
    store:properties "id:string,type:ActionType,target_id:string,store_id:string,assignee_id:string,status:TaskStatus,params_json:dict,result_json:dict,priority:Priority,notes:string,created_at:datetime,started_at:datetime,completed_at:datetime" ;
    store:storage "tasks.json" .

# ============================================================
# Link Types (关系类型)
# ============================================================

store:located_in a rdfs:Property ;
    rdfs:label "位于"@zh , "located in"@en ;
    rdfs:domain store:Store ;
    rdfs:range store:Region ;
    store:via "region_id" .

store:has_employee a rdfs:Property ;
    rdfs:label "拥有员工"@zh , "has employee"@en ;
    rdfs:domain store:Store ;
    rdfs:range store:Employee ;
    store:via "store_id" .

store:has_near_expiry a rdfs:Property ;
    rdfs:label "拥有临期商品"@zh , "has near expiry product"@en ;
    rdfs:domain store:Store ;
    rdfs:range store:NearExpiryProduct ;
    store:via "store_id" .

store:is_instance_of a rdfs:Property ;
    rdfs:label "是...的实例"@zh , "is instance of"@en ;
    rdfs:domain store:NearExpiryProduct ;
    rdfs:range store:Product ;
    store:via "product_id" .

store:manages a rdfs:Property ;
    rdfs:label "管理"@zh , "manages"@en ;
    rdfs:domain store:Employee ;
    rdfs:range store:Store ;
    store:via "manager_id" .

store:has_task a rdfs:Property ;
    rdfs:label "有任务"@zh , "has task"@en ;
    rdfs:domain store:Store ;
    rdfs:range store:Task ;
    store:via "store_id" .

store:created_for a rdfs:Property ;
    rdfs:label "针对"@zh , "created for"@en ;
    rdfs:domain store:Task ;
    rdfs:range store:NearExpiryProduct ;
    store:via "target_id" .

# ============================================================
# Action Types (动作类型)
# clearance: 对临期商品进行出清处理
# transfer: 门店间调拨商品
# restock: 补充商品库存
# ============================================================

store:clearance a rdfs:Class ;
    rdfs:label "出清"@zh , "Clearance"@en ;
    rdfs:comment "对临期商品进行出清处理"@zh ;
    store:target store:NearExpiryProduct ;
    store:params "discount:int,quantity:int,notes:string" .

store:transfer a rdfs:Class ;
    rdfs:label "调拨"@zh , "Transfer"@en ;
    rdfs:comment "门店间调拨商品"@zh ;
    store:target store:Product ;
    store:params "from_store:string,to_store:string,quantity:int,notes:string" .

store:restock a rdfs:Class ;
    rdfs:label "补货"@zh , "Restock"@en ;
    rdfs:comment "补充商品库存"@zh ;
    store:target store:Product ;
    store:params "quantity:int,supplier_id:string,notes:string" .
