so:ParameterSource a owl:Class ;
    rdfs:label "参数来源"@zh-CN ;
    rdfs:comment "Action参数的数据来源"@zh-CN .

so:ParameterSourceUserInput a owl:NamedIndividual ;
    rdfs:label "用户输入"@zh-CN ;
    rdfs:label "User Input"@en ;
    rdfs:subClassOf so:ParameterSource .

so:ParameterSourceSystemDefault a owl:NamedIndividual ;
    rdfs:label "系统默认值"@zh-CN ;
    rdfs:label "System Default"@en ;
    rdfs:subClassOf so:ParameterSource .

so:ParameterSourceDerived a owl:NamedIndividual ;
    rdfs:label "派生值"@zh-CN ;
    rdfs:label "Derived Value"@en ;
    rdfs:subClassOf so:ParameterSource .

# ------------------------------------------------------------
# 辅助类：写入操作类型
# ------------------------------------------------------------
so:WriteOperation a owl:Class ;
    rdfs:label "写入操作类型"@zh-CN ;
    rdfs:comment "Action写入属性时的操作类型"@zh-CN .

so:WriteOperationSet a owl:NamedIndividual ;
    rdfs:label "设置值"@zh-CN ;
    rdfs:label "Set Value"@en ;
    rdfs:subClassOf so:WriteOperation .

so:WriteOperationAppend a owl:NamedIndividual ;
    rdfs:label "追加值"@zh-CN ;
    rdfs:label "Append Value"@en ;
    rdfs:subClassOf so:WriteOperation .

so:WriteOperationCreate a owl:NamedIndividual ;
    rdfs:label "新建对象"@zh-CN ;
    rdfs:label "Create Object"@en ;
    rdfs:subClassOf so:WriteOperation .

so:WriteOperationConditional a owl:NamedIndividual ;
    rdfs:label "条件写入"@zh-CN ;
    rdfs:label "Conditional Write"@en ;
    rdfs:subClassOf so:WriteOperation .

# ------------------------------------------------------------
# 辅助类：条件运算符
# ------------------------------------------------------------
so:Operator a owl:Class ;
    rdfs:label "条件运算符"@zh-CN ;
    rdfs:comment "提交条件的比较运算符"@zh-CN .

so:OperatorEquals a owl:NamedIndividual ;
    rdfs:label "等于"@zh-CN ;
    rdfs:label "Equals"@en ;
    rdfs:subClassOf so:Operator .

so:OperatorNotNull a owl:NamedIndividual ;
    rdfs:label "不为空"@zh-CN ;
    rdfs:label "Not Null"@en ;
    rdfs:subClassOf so:Operator .

so:OperatorLinkExists a owl:NamedIndividual ;
    rdfs:label "链接存在"@zh-CN ;
    rdfs:label "Link Exists"@en ;
    rdfs:subClassOf so:Operator .

# ------------------------------------------------------------
# 辅助类：副作用类型
# ------------------------------------------------------------
so:SideEffectType a owl:Class ;
    rdfs:label "副作用类型"@zh-CN ;
    rdfs:comment "Action副作用的类型"@zh-CN .

so:SideEffectTypeNotification a owl:NamedIndividual ;
    rdfs:label "通知"@zh-CN ;
    rdfs:label "Notification"@en ;
    rdfs:subClassOf so:SideEffectType .

so:SideEffectTypeChainAction a owl:NamedIndividual ;
    rdfs:label "链式Action"@zh-CN ;
    rdfs:label "Chain to Another Action"@en ;
    rdfs:subClassOf so:SideEffectType .

so:SideEffectTypePrompt a owl:NamedIndividual ;
    rdfs:label "用户提示"@zh-CN ;
    rdfs:label "User Prompt"@en ;
    rdfs:subClassOf so:SideEffectType .

# ------------------------------------------------------------
# 辅助类：角色
# ------------------------------------------------------------
so:Role a owl:Class ;
    rdfs:label "角色"@zh-CN ;
    rdfs:comment "通知或权限相关的角色"@zh-CN .

so:RoleStoreManager a owl:NamedIndividual ;
    rdfs:label "店长"@zh-CN ;
    rdfs:label "Store Manager"@en ;
    rdfs:subClassOf so:Role .

so:RoleFrontline a owl:NamedIndividual ;
    rdfs:label "一线员工"@zh-CN ;
    rdfs:label "Frontline Employee"@en ;
    rdfs:subClassOf so:Role .

